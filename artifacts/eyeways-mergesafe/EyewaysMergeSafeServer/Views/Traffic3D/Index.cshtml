@model EyewaysMergeSafeServer.ViewModels.Traffic3DViewModel
@{ ViewData["Title"] = "3D Traffic"; ViewBag.Highways = Model.Highways; ViewBag.SelectedHighwayId = Model.SelectedHighwayId; }
@{
    var zones   = Model.Zones;
    var sensors = Model.Sensors;
    var servers = Model.SwitchServers;
}

<div class="mss-page-header">
    <div><h2 class="mss-page-title">3D Traffic Visualization</h2><p class="mss-page-sub">Highway map with Leaflet overlays and Three.js Scene3D</p></div>
    <div class="d-flex gap-2">
        <button id="btnMap" class="btn btn-primary btn-sm" onclick="setMode('map')"><i class="bi bi-map me-1"></i>Map</button>
        <button id="btn3d"  class="btn btn-outline-secondary btn-sm" onclick="setMode('3d')"><i class="bi bi-badge-3d me-1"></i>3D Scene</button>
    </div>
</div>

<div class="row g-3">
    <!-- ── Left: map / 3D canvas ─────────────────────────────────────────── -->
    <div class="col-lg-9">
        <div id="mapPanel" class="mss-card">
            <div class="mss-card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-map me-1"></i> Highway Map</span>
                <div class="d-flex align-items-center gap-2">
                    <span id="mapZoneLabel" class="badge bg-primary" style="display:none"></span>
                    <span class="text-muted small" id="mapRefreshTimer">Refreshes in 5:00</span>
                </div>
            </div>
            <div id="leafletMap" style="height:500px;border-radius:0 0 12px 12px;"></div>
        </div>

        <div id="scene3dPanel" class="mss-card" style="display:none">
            <div class="mss-card-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <span><i class="bi bi-badge-3d me-1"></i> Scene3D — Three.js WebGL</span>
                    <span id="scene3dZoneLabel" class="badge bg-primary" style="display:none"></span>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <button id="btnAnimToggle" class="btn btn-outline-warning btn-sm" onclick="toggleAnimation()" style="display:none">
                        <i class="bi bi-pause-fill me-1"></i>Pause
                    </button>
                    <button id="btnLoadScene" class="btn btn-outline-info btn-sm" onclick="loadSceneFromDB()" style="display:none" title="Load saved simulation records into 3D scene">
                        <i class="bi bi-cloud-download me-1"></i>Load Saved
                    </button>
                    <a href="/Vehicles" class="btn btn-outline-secondary btn-sm"><i class="bi bi-car-front me-1"></i>Vehicle Registry</a>
                </div>
            </div>
            <div id="scene3dContainer" style="width:100%;height:500px;border-radius:0 0 12px 12px;overflow:hidden;position:relative;">
                <!-- Zone overlay inside 3D canvas -->
                <div id="zoneOverlay" style="display:none;position:absolute;top:10px;left:10px;z-index:10;
                     background:rgba(10,15,26,.75);backdrop-filter:blur(4px);border:1px solid rgba(255,255,255,.12);
                     border-radius:8px;padding:6px 12px;pointer-events:none">
                    <span class="text-muted" style="font-size:.68rem">FILTERING</span><br>
                    <span id="overlayZoneName" class="fw-semibold" style="font-size:.85rem;color:#f59e0b"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Right: sidebar ────────────────────────────────────────────────── -->
    <div class="col-lg-3">

        <!-- Zones list -->
        <div class="mss-card mb-3">
            <div class="mss-card-header"><i class="bi bi-diagram-2 me-1"></i> Zones</div>
            <div class="mss-card-body p-0" style="max-height:180px;overflow-y:auto">
                @foreach (var z in zones)
                {
                    <div class="mss-list-item d-flex justify-content-between align-items-center zone-list-item"
                         data-zone-id="@z.ZoneId" style="cursor:pointer"
                         onclick="selectZone('@z.ZoneId')" title="Filter to @z.ZoneName">
                        <span class="small">@z.ZoneName</span>
                        <span class="mss-badge mss-badge--@z.Status">@z.Status</span>
                    </div>
                }
                @if (!zones.Any())
                { <p class="text-muted small p-2">No zones.</p> }
            </div>
        </div>

        <!-- Controls (camera / speed / density / zone filter) -->
        <div class="mss-card mb-3">
            <div class="mss-card-header"><i class="bi bi-sliders me-1"></i> Controls</div>
            <div class="mss-card-body">
                <label class="form-label small">Camera Angle</label>
                <input type="range" class="form-range mb-2" id="camAngle" min="10" max="80" step="5" value="45" oninput="setCamAngle(this.value)" />
                <label class="form-label small">Speed Multiplier</label>
                <input type="range" class="form-range mb-2" id="speedMult" min="0.5" max="5" step="0.5" value="1" oninput="setSpeedMult(this.value)" />
                <label class="form-label small">Vehicle Density</label>
                <input type="range" class="form-range mb-3" id="density" min="3" max="30" step="1" value="10" oninput="setDensity(this.value)" />

                <hr class="border-secondary my-0 mb-3" />

                <label class="form-label small d-flex justify-content-between">
                    <span><i class="bi bi-funnel me-1"></i>Zone / Server Filter</span>
                    <button class="btn btn-link btn-sm p-0 text-muted" style="font-size:.7rem" onclick="selectZone('')">Clear</button>
                </label>
                <select class="form-select form-select-sm" id="zoneFilterSelect"
                        onchange="selectZone(this.value)"
                        style="background:#0f1624;border-color:rgba(255,255,255,.18);color:#e2e8f0">
                    <option value="">All Zones</option>
                    @foreach (var z in zones)
                    {
                        <option value="@z.ZoneId">@z.ZoneName</option>
                    }
                </select>

                @if (servers.Any())
                {
                    <div class="mt-2">
                        <label class="form-label small"><i class="bi bi-hdd-network me-1"></i>Switch Server</label>
                        <select class="form-select form-select-sm" id="serverFilterSelect"
                                onchange="selectZoneByServer(this.value)"
                                style="background:#0f1624;border-color:rgba(255,255,255,.18);color:#e2e8f0">
                            <option value="">All Servers</option>
                            @foreach (var s in servers)
                            {
                                <option value="@s.ZoneId" data-server-id="@s.ServerId">@s.ServerName (@s.ZoneId)</option>
                            }
                        </select>
                    </div>
                }
            </div>
        </div>

        <!-- Zone detail panel (visible when a zone is selected) -->
        <div class="mss-card mb-3" id="zoneDetailCard" style="display:none">
            <div class="mss-card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-hdd-network me-1"></i> <span id="zoneDetailTitle">Zone Servers</span></span>
                <span id="zoneDetailBadge" class="mss-badge"></span>
            </div>
            <div class="mss-card-body p-0" id="zoneServerList" style="max-height:200px;overflow-y:auto"></div>
        </div>

        <!-- Live feed -->
        <div class="mss-card">
            <div class="mss-card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-activity me-1"></i> <span id="feedTitle">Live Feed</span>
                    <span id="simModeBadge" style="display:none;font-size:.58rem;vertical-align:middle;margin-left:4px;background:#f59e0b;color:#000;padding:1px 5px;border-radius:4px;font-weight:700">
                        <i class="bi bi-cpu me-1"></i>SIM
                    </span>
                </span>
                <span id="livePulseBadge" class="mss-badge mss-badge--active" style="animation:pulse 1s infinite">LIVE</span>
            </div>
            <div class="mss-card-body p-0" id="trafficFeed" style="max-height:260px;overflow-y:auto">
                <p class="text-muted small p-2">Switch to 3D Scene to start feed…</p>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<style>
.mss-zone-tooltip{background:rgba(10,15,26,.9)!important;border:1px solid rgba(255,255,255,.2)!important;color:#e2e8f0!important;font-size:.67rem!important;font-weight:700!important;box-shadow:none!important;padding:2px 8px!important;white-space:nowrap!important;}
.mss-zone-tooltip::before{border-top-color:rgba(255,255,255,.2)!important;}
</style>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha384-sHL9NAb7lN7rfvG5lfHpm643Xkcjzp4jFvuavGOndn6pjVqS6ny56CAt3nsEVT4H"
      crossorigin="anonymous" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha384-cxOPjt7s7Iz04uaHJceBmS+qpjv2JkIHNVcuOrM+YHwZOmJGBXI00mdUXEq65HTH"
        crossorigin="anonymous"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"
        integrity="sha384-9EQoUIJYrv09/oYhSxnw1VpLcfPw3BM9dE7+D/3wGUPeLLa7F9Z6OAoD+i/M6FK9"
        crossorigin="anonymous"></script>
<script src="~/js/vehicleScene.js"></script>
<script>
// ── Server-side data ─────────────────────────────────────────────────────────
var highwayId = '@(Model.SelectedHighwayId ?? "")';

var sensorData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    sensors.Where(s => s.Latitude.HasValue && s.Longitude.HasValue)
           .Select(s => new { s.DeviceName, s.DeviceType, s.Status, lat = s.Latitude, lon = s.Longitude })));

var zoneData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    zones.Where(z => z.Latitude.HasValue && z.Longitude.HasValue)
         .Select(z => new {
             zoneId   = z.ZoneId,
             zoneName = z.ZoneName,
             status   = z.Status,
             lat      = z.Latitude,
             lon      = z.Longitude,
             r        = z.GeofenceRadius
         })));

var serversByZone = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    servers.GroupBy(s => s.ZoneId ?? "")
           .ToDictionary(
               g => g.Key,
               g => g.Select(s => new {
                   serverId   = s.ServerId,
                   serverName = s.ServerName,
                   ipAddress  = s.IpAddress,
                   port       = s.Port,
                   status     = s.Status
               }).ToList()
           )));

// ── Zone selection state ─────────────────────────────────────────────────────
var selectedZoneId = '';

function selectZone(zoneId) {
    selectedZoneId = zoneId || '';
    // Sync dropdowns
    document.getElementById('zoneFilterSelect').value = selectedZoneId;
    var ss = document.getElementById('serverFilterSelect');
    if (ss) ss.value = selectedZoneId ? selectedZoneId : '';

    // Highlight zone list items
    document.querySelectorAll('.zone-list-item').forEach(function(el) {
        var active = el.dataset.zoneId === selectedZoneId;
        el.style.background    = active ? 'rgba(59,130,246,.15)'  : '';
        el.style.borderLeft    = active ? '3px solid #3b82f6'     : '3px solid transparent';
        el.style.paddingLeft   = active ? '9px'                   : '';
    });

    updateMapHighlight(selectedZoneId);
    updateZoneDetailPanel(selectedZoneId);
    updateFeedTitle(selectedZoneId);
    updateSceneZoneLabel(selectedZoneId);

    // Reset poll time so new zone events load immediately
    lastPollTime = new Date().toISOString();
    if (scene3dInitialized) pollLiveEvents();
}

function selectZoneByServer(zoneId) {
    // Show the map first so the fly-to zoom is visible, then filter
    setMode('map');
    selectZone(zoneId);
}

// ── Leaflet map ──────────────────────────────────────────────────────────────
var mapCenter = zoneData.length > 0 ? [zoneData[0].lat, zoneData[0].lon] : [32.7767, -96.7970];
var map = L.map('leafletMap').setView(mapCenter, 10);
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', { attribution:'© OSM, CARTO' }).addTo(map);

sensorData.forEach(function(s) {
    var color = {camera:'#3b82f6',lidar:'#a855f7',radar:'#f59e0b','vehicle tag reader':'#22c55e'}[s.deviceType] || '#fff';
    L.circleMarker([s.lat, s.lon], {radius:5, color:color, fillColor:color, fillOpacity:0.9})
        .bindPopup('<b>'+s.deviceName+'</b><br>'+s.deviceType+'<br>'+s.status).addTo(map);
});

// Highway polyline — connect zones in order to show the route
if (zoneData.length > 1) {
    L.polyline(zoneData.map(function(z){ return [z.lat, z.lon]; }),
        { color: '#3b82f6', weight: 4, opacity: 0.42, dashArray: '10 6' }).addTo(map);
}

// Draw zone circles and keep refs for highlight updates
var mapZoneRefs = [];
zoneData.forEach(function(z) {
    var base = z.status === 'fault' ? '#ef4444' : '#22c55e';
    var circle = L.circle([z.lat, z.lon], {radius: z.r || 500, color: base, fillColor: base, fillOpacity: 0.12, weight: 2})
        .addTo(map);
    var marker = L.circleMarker([z.lat, z.lon], {radius: 10, color: base, fillColor: base, fillOpacity: 0.95, weight: 2})
        .bindPopup(
            '<div style="min-width:150px">' +
            '<b style="font-size:.85rem">' + z.zoneName + '</b>' +
            ' <span style="font-size:.7rem;color:' + base + '">● ' + z.status + '</span>' +
            '<br><code style="font-size:.68rem;color:#94a3b8">' + z.zoneId + '</code>' +
            '<br><a href="#" onclick="selectZone(\'' + z.zoneId + '\');return false;" ' +
                'style="font-size:.75rem;color:#60a5fa">Filter to this zone →</a>' +
            '</div>')
        .bindTooltip(z.zoneName, { permanent: true, direction: 'top', offset: [0, -14], className: 'mss-zone-tooltip' })
        .on('click', function() { selectZone(z.zoneId); })
        .addTo(map);
    mapZoneRefs.push({ zoneId: z.zoneId, zoneName: z.zoneName, circle: circle, marker: marker, base: base, lat: z.lat, lon: z.lon });
});

function updateMapHighlight(zoneId) {
    mapZoneRefs.forEach(function(ref) {
        var sel = zoneId && ref.zoneId === zoneId;
        ref.circle.setStyle({
            color:       sel ? '#f59e0b' : ref.base,
            fillOpacity: sel ? 0.22      : 0.1,
            weight:      sel ? 3         : 1
        });
        ref.marker.setStyle({
            color:       sel ? '#f59e0b' : ref.base,
            fillColor:   sel ? '#f59e0b' : ref.base,
            radius:      sel ? 13        : 8
        });
        if (sel) map.flyTo([ref.lat, ref.lon], 12, { duration: 0.8 });
    });
    var label = document.getElementById('mapZoneLabel');
    if (zoneId) {
        var z = zoneData.find(function(z) { return z.zoneId === zoneId; });
        label.textContent = z ? z.zoneName : zoneId;
        label.style.display = '';
    } else {
        label.style.display = 'none';
        if (zoneData.length) map.flyTo(mapCenter, 10, { duration: 0.8 });
    }
}

loadSegments();
function loadSegments() {
    fetch('/Traffic3D/GetTrafficSegments?highwayId=' + encodeURIComponent(highwayId))
        .then(function(r) { return r.json(); })
        .then(renderSegFeed)
        .catch(function() { renderSegFeed({ segments: [] }); });
}
function renderSegFeed(data) {
    var segs = (data.segments || []);
    if (!segs.length) return;
    var cm = { free: '#22c55e', moderate: '#f59e0b', heavy: '#ef4444' };
    var feed = document.getElementById('trafficFeed');
    feed.innerHTML = segs.map(function(s) {
        var c = cm[s.congestion] || '#64748b';
        return '<div class="mss-list-item d-flex justify-content-between align-items-center">' +
            '<span class="small fw-semibold" style="color:'+c+'">'+s.name+'</span>' +
            '<span class="small text-muted">'+s.speedMph+' mph</span></div>';
    }).join('');
}

// ── Zone detail panel ────────────────────────────────────────────────────────
function updateZoneDetailPanel(zoneId) {
    var card  = document.getElementById('zoneDetailCard');
    var title = document.getElementById('zoneDetailTitle');
    var badge = document.getElementById('zoneDetailBadge');
    var list  = document.getElementById('zoneServerList');

    if (!zoneId) { card.style.display = 'none'; return; }

    var zone    = zoneData.find(function(z) { return z.zoneId === zoneId; });
    var srvList = serversByZone[zoneId] || [];
    card.style.display = '';
    title.textContent  = zone ? zone.zoneName : zoneId;
    badge.textContent  = zone ? zone.status : '';
    badge.className    = 'mss-badge mss-badge--' + (zone ? zone.status : 'active');

    if (!srvList.length) {
        list.innerHTML = '<p class="text-muted small p-2">No servers assigned to this zone.</p>';
        return;
    }
    list.innerHTML = srvList.map(function(s) {
        var dot = s.status === 'online' ? '#22c55e' : s.status === 'fault' ? '#ef4444' : '#f59e0b';
        return '<div class="mss-list-item d-flex justify-content-between align-items-center">' +
            '<div>' +
            '<div class="small fw-semibold">' + s.serverName + '</div>' +
            '<div class="font-monospace text-muted" style="font-size:.63rem">' +
                (s.ipAddress || '—') + ':' + s.port +
            '</div>' +
            '</div>' +
            '<span class="mss-badge mss-badge--' + s.status + '">' + s.status + '</span>' +
            '</div>';
    }).join('');
}

function updateFeedTitle(zoneId) {
    var title = document.getElementById('feedTitle');
    if (zoneId) {
        var z = zoneData.find(function(z) { return z.zoneId === zoneId; });
        title.textContent = (z ? z.zoneName : zoneId) + ' Feed';
    } else {
        title.textContent = 'Live Feed';
    }
}

function updateSceneZoneLabel(zoneId) {
    var overlay = document.getElementById('zoneOverlay');
    var nameEl  = document.getElementById('overlayZoneName');
    var scLabel = document.getElementById('scene3dZoneLabel');
    if (zoneId) {
        var z = zoneData.find(function(z) { return z.zoneId === zoneId; });
        var name = z ? z.zoneName : zoneId;
        nameEl.textContent   = name;
        overlay.style.display = '';
        scLabel.textContent  = name;
        scLabel.style.display = '';
    } else {
        overlay.style.display = 'none';
        scLabel.style.display = 'none';
    }
}

// ── Animation play/pause ─────────────────────────────────────────────────────
var animationPaused = false;
function toggleAnimation() {
    closeVehicleDetail();
    animationPaused = !animationPaused;
    var btn       = document.getElementById('btnAnimToggle');
    var feedTitle = document.getElementById('feedTitle');
    var simBadge  = document.getElementById('simModeBadge');
    var liveBadge = document.getElementById('livePulseBadge');
    if (!btn) return;
    btn.innerHTML = animationPaused
        ? '<i class="bi bi-play-fill me-1"></i>Resume'
        : '<i class="bi bi-pause-fill me-1"></i>Pause';
    btn.className = animationPaused ? 'btn btn-success btn-sm' : 'btn btn-outline-warning btn-sm';

    if (animationPaused) {
        // ── PAUSED: clear scene, stop live feed, start simulation-only ───
        // 1. Remove every vehicle mesh from the WebGL scene
        vehicles3d.forEach(function(v) { scene3d.remove(v); });
        vehicles3d.length = 0;
        // 2. Clear feed panel
        feedItems3d.length = 0;
        var feedEl = document.getElementById('trafficFeed');
        if (feedEl) feedEl.innerHTML =
            '<p class="text-muted small p-2"><i class="bi bi-cpu me-2"></i>' +
            'Scene cleared — waiting for simulation events…</p>';
        // 3. Switch polling to simulation-only
        if (liveEventInterval) { clearInterval(liveEventInterval); liveEventInterval = null; }
        lastSimPollTime = new Date(Date.now() - 5000).toISOString();
        simEventInterval = setInterval(pollSimulationEvents, 3000);
        pollSimulationEvents();
        // 4. Update UI indicators
        if (feedTitle) { feedTitle.textContent = 'Simulation Feed'; feedTitle.style.color = '#f59e0b'; }
        if (simBadge)  simBadge.style.display = '';
        if (liveBadge) { liveBadge.textContent = 'SIM ONLY'; liveBadge.style.background = '#92400e'; }
    } else {
        // ── RESUMED: clear sim vehicles, restart live feed ────────────────
        // 1. Remove simulation vehicles from WebGL scene
        vehicles3d.forEach(function(v) { scene3d.remove(v); });
        vehicles3d.length = 0;
        // 2. Clear feed
        feedItems3d.length = 0;
        var feedEl = document.getElementById('trafficFeed');
        if (feedEl) feedEl.innerHTML =
            '<p class="text-muted small p-2"><i class="bi bi-arrow-repeat me-2"></i>' +
            'Resuming live feed…</p>';
        // 3. Switch polling back to live
        if (simEventInterval) { clearInterval(simEventInterval); simEventInterval = null; }
        liveEventInterval = setInterval(pollLiveEvents, 3000);
        lastPollTime = new Date(Date.now() - 10000).toISOString();
        pollLiveEvents();
        // 4. Restore UI indicators
        if (feedTitle) { feedTitle.textContent = 'Live Feed'; feedTitle.style.color = ''; }
        if (simBadge)  simBadge.style.display = 'none';
        if (liveBadge) { liveBadge.textContent = 'LIVE'; liveBadge.style.background = ''; }
    }
}

// ── Mode toggle ──────────────────────────────────────────────────────────────
var scene3dInitialized = false;
function setMode(m) {
    document.getElementById('mapPanel').style.display     = m === 'map' ? '' : 'none';
    document.getElementById('scene3dPanel').style.display = m === '3d'  ? '' : 'none';
    document.getElementById('btnMap').className = m === 'map' ? 'btn btn-primary btn-sm' : 'btn btn-outline-secondary btn-sm';
    document.getElementById('btn3d').className  = m === '3d'  ? 'btn btn-primary btn-sm' : 'btn btn-outline-secondary btn-sm';

    if (m === '3d') {
        if (!scene3dInitialized) {
            initScene3D();
        } else {
            // Already running — flush feed and immediately re-poll for current zone
            feedItems3d = [];
            var zLabel = selectedZoneId
                ? (zoneData.find(function(z) { return z.zoneId === selectedZoneId; }) || {}).zoneName || selectedZoneId
                : null;
            document.getElementById('trafficFeed').innerHTML =
                '<p class="text-muted small p-2">' +
                (zLabel ? 'Loading feed for <strong>' + zLabel + '</strong>…' : 'Refreshing live feed…') +
                '</p>';
            lastPollTime = new Date(Date.now() - 30000).toISOString();
            pollLiveEvents();
        }
        updateSceneZoneLabel(selectedZoneId);
    }

    if (m === 'map') {
        // Returning to map — restore segment feed if no live items yet
        updateFeedTitle(selectedZoneId);
        if (!feedItems3d.length) loadSegments();
    }
}

// ── Three.js Scene3D ─────────────────────────────────────────────────────────
var speedMult = 1, density = 10, camAngleVal = 45;
var renderer3d, camera3d, scene3d, vehicles3d = [];
var raycaster3d = null, mouse3d = null, selectedVehicle3d = null;

function setCamAngle(v) {
    camAngleVal = parseFloat(v);
    if (camera3d) {
        var d = 35, rad = camAngleVal * Math.PI / 180;
        camera3d.position.set(0, Math.sin(rad) * d, Math.cos(rad) * d);
        camera3d.lookAt(0, 0, 0);
    }
}
function setSpeedMult(v) { speedMult = parseFloat(v); }
function setDensity(v)   { density   = parseInt(v);   }

function initScene3D() {
    scene3dInitialized = true;
    var container = document.getElementById('scene3dContainer');
    var W = container.clientWidth, H = container.clientHeight;

    scene3d = new THREE.Scene();
    scene3d.background = new THREE.Color(0x0a0f1a);
    scene3d.fog = new THREE.FogExp2(0x0a0f1a, 0.016);

    camera3d = new THREE.PerspectiveCamera(45, W / H, 0.1, 500);
    camera3d.position.set(0, 22, 28);
    camera3d.lookAt(0, 0, 0);

    renderer3d = new THREE.WebGLRenderer({ antialias: true });
    renderer3d.setSize(W, H);
    renderer3d.setPixelRatio(window.devicePixelRatio);
    renderer3d.shadowMap.enabled = true;
    container.appendChild(renderer3d.domElement);

    scene3d.add(new THREE.AmbientLight(0x334466, 2));
    var dir = new THREE.DirectionalLight(0x8899ff, 2.5);
    dir.position.set(10, 20, 10); dir.castShadow = true;
    scene3d.add(dir);

    // Ground
    var gnd = new THREE.Mesh(new THREE.PlaneGeometry(120, 120),
        new THREE.MeshLambertMaterial({ color: 0x050a12 }));
    gnd.rotation.x = -Math.PI / 2; gnd.receiveShadow = true;
    scene3d.add(gnd);

    // Road (6 lanes total — 3 each direction)
    var road = new THREE.Mesh(new THREE.PlaneGeometry(14, 80),
        new THREE.MeshLambertMaterial({ color: 0x1a2035 }));
    road.rotation.x = -Math.PI / 2; road.position.y = 0.02; road.receiveShadow = true;
    scene3d.add(road);

    // Median
    var med = new THREE.Mesh(new THREE.PlaneGeometry(0.4, 80),
        new THREE.MeshLambertMaterial({ color: 0x2a3a55 }));
    med.rotation.x = -Math.PI / 2; med.position.y = 0.025;
    scene3d.add(med);

    // Lane markers
    for (var zi = -36; zi < 37; zi += 6) {
        [-5, -3, 3, 5].forEach(function(xl) {
            var lm = new THREE.Mesh(new THREE.PlaneGeometry(0.12, 3),
                new THREE.MeshBasicMaterial({ color: Math.abs(xl) === 5 ? 0xffffff : 0xffff00 }));
            lm.rotation.x = -Math.PI / 2; lm.position.set(xl, 0.03, zi);
            scene3d.add(lm);
        });
    }

    // Curbs
    [-7.2, 7.2].forEach(function(cx) {
        var curb = new THREE.Mesh(new THREE.BoxGeometry(0.25, 0.12, 80),
            new THREE.MeshLambertMaterial({ color: 0x2c3a52 }));
        curb.position.set(cx, 0.06, 0);
        scene3d.add(curb);
    });

    vehicles3d = [];
    for (var vi = 0; vi < density; vi++) spawnV();
    animate3d();
    startEventPolling();

    var tb = document.getElementById('btnAnimToggle');
    if (tb) { tb.style.display = ''; animationPaused = false; }
    var lsb = document.getElementById('btnLoadScene');
    if (lsb) lsb.style.display = '';

    // Auto-enter simulation mode if a simulation was already running in another tab
    try {
        if (localStorage.getItem('eyeways_sim_active') === 'true') {
            setTimeout(function() { if (!animationPaused) toggleAnimation(); }, 500);
        }
    } catch(e) {}

    // ── Click-to-inspect: raycaster setup ────────────────────────────────────
    raycaster3d = new THREE.Raycaster();
    mouse3d     = new THREE.Vector2();

    // Build the floating detail panel inside the canvas container
    var vpanel = document.createElement('div');
    vpanel.id = 'vehicleDetailPanel';
    vpanel.style.cssText =
        'display:none;position:absolute;top:0;left:0;z-index:20;width:300px;' +
        'background:rgba(8,12,24,.97);border:1px solid rgba(255,255,255,.14);' +
        'border-radius:10px;backdrop-filter:blur(8px);' +
        'box-shadow:0 8px 32px rgba(0,0,0,.6);overflow:hidden;';
    vpanel.innerHTML =
        '<div style="padding:9px 12px;border-bottom:1px solid rgba(255,255,255,.09);' +
            'display:flex;justify-content:space-between;align-items:center">' +
            '<span id="vdTitle" style="font-size:.8rem;font-weight:700;color:#e2e8f0;' +
                'white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:250px"></span>' +
            '<button id="vdClose" style="background:none;border:none;color:#94a3b8;' +
                'font-size:1.1rem;cursor:pointer;line-height:1;padding:0 2px;flex-shrink:0">' +
                '×</button>' +
        '</div>' +
        '<div style="display:flex;border-bottom:1px solid rgba(255,255,255,.07)">' +
            '<button id="vdTabFmt" onclick="vdSwitchTab(\'fmt\')" ' +
                'style="flex:1;padding:5px;font-size:.7rem;font-weight:600;' +
                'background:rgba(59,130,246,.18);border:none;color:#60a5fa;cursor:pointer">' +
                'Formatted</button>' +
            '<button id="vdTabRaw" onclick="vdSwitchTab(\'raw\')" ' +
                'style="flex:1;padding:5px;font-size:.7rem;font-weight:600;' +
                'background:transparent;border:none;color:#64748b;cursor:pointer">' +
                'Raw JSON</button>' +
        '</div>' +
        '<div id="vdBodyFmt" style="padding:10px 12px;max-height:240px;overflow-y:auto"></div>' +
        '<div id="vdBodyRaw" style="display:none;padding:10px 12px;max-height:240px;overflow-y:auto">' +
            '<pre id="vdRawPre" style="font-size:.6rem;color:#94a3b8;white-space:pre-wrap;' +
                'word-break:break-all;margin:0;line-height:1.5"></pre>' +
        '</div>';
    container.appendChild(vpanel);
    vpanel.addEventListener('click', function(e) { e.stopPropagation(); });
    document.getElementById('vdClose').addEventListener('click', closeVehicleDetail);

    // Hover: change cursor when over a vehicle
    container.addEventListener('mousemove', function(e) {
        if (!raycaster3d || !camera3d) return;
        var rect = renderer3d.domElement.getBoundingClientRect();
        mouse3d.x =  ((e.clientX - rect.left) / rect.width)  * 2 - 1;
        mouse3d.y = -((e.clientY - rect.top)  / rect.height) * 2 + 1;
        raycaster3d.setFromCamera(mouse3d, camera3d);
        var hits = raycaster3d.intersectObjects(vehicles3d, true);
        container.style.cursor = hits.length ? 'pointer' : '';
    });

    // Click: pick vehicle and show detail panel
    container.addEventListener('click', function(e) {
        var panel = document.getElementById('vehicleDetailPanel');
        if (panel && panel.contains(e.target)) return;
        if (!raycaster3d || !camera3d) return;
        var rect = renderer3d.domElement.getBoundingClientRect();
        mouse3d.x =  ((e.clientX - rect.left) / rect.width)  * 2 - 1;
        mouse3d.y = -((e.clientY - rect.top)  / rect.height) * 2 + 1;
        raycaster3d.setFromCamera(mouse3d, camera3d);
        var hits = raycaster3d.intersectObjects(vehicles3d, true);
        if (!hits.length) { closeVehicleDetail(); return; }
        var obj = hits[0].object;
        while (obj.parent && vehicles3d.indexOf(obj) < 0) obj = obj.parent;
        if (vehicles3d.indexOf(obj) < 0) { closeVehicleDetail(); return; }
        showVehicleDetail(obj, e.clientX, e.clientY);
    });

    // Keyboard dismiss
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeVehicleDetail();
    });

    // Outside-page dismiss: clicking sidebar, header, or any element outside the canvas container
    document.addEventListener('click', function(e) {
        var panel = document.getElementById('vehicleDetailPanel');
        if (!panel || panel.style.display === 'none') return;
        var cont = document.getElementById('scene3dContainer');
        if (cont && !cont.contains(e.target)) closeVehicleDetail();
    }, true);

    window.addEventListener('resize', function() {
        if (!renderer3d) return;
        var W2 = container.clientWidth, H2 = container.clientHeight;
        renderer3d.setSize(W2, H2);
        camera3d.aspect = W2 / H2;
        camera3d.updateProjectionMatrix();
    });
}

// ── Vehicle spawning ─────────────────────────────────────────────────────────

function spawnV(vSpec, fromEvent, zoneId, isSimulation, ev) {
    if (!vSpec) vSpec = vehicleGetRandom(ev && ev.vehicleType ? ev.vehicleType : null);
    var group = vehicleBuildMesh(vSpec);
    // Use cardinal direction from event if available, otherwise assign by lane
    var cardinal  = ev && ev.direction ? ev.direction : null;
    var lanePool  = cardinal === 'N' ? [-4,-2] : cardinal === 'S' ? [2,4]
                  : cardinal === 'E' ? [2,4]   : cardinal === 'W' ? [-4,-2]
                  : [-4,-2,2,4];
    var lane      = lanePool[Math.floor(Math.random() * lanePool.length)];
    if (!cardinal) cardinal = lane < 0 ? 'N' : 'S';
    group.position.set(lane, 0, (Math.random() * 80) - 40);
    // Rotate mesh to face correct direction
    var rotY = cardinal === 'N' ? Math.PI : cardinal === 'S' ? 0
             : cardinal === 'E' ? -Math.PI/2 : Math.PI/2;
    group.rotation.y = rotY;
    group.userData = {
        speed:        ev && ev.speedMph ? ev.speedMph * 0.012 : (25 + Math.random() * 55) * 0.012,
        dir:          cardinal === 'N' || cardinal === 'W' ? -1 : 1,
        cardinal:     cardinal,
        lane:         lane,
        type:         vSpec.type,
        make:         vSpec.make,
        model:        vSpec.model,
        icon:         vSpec.icon,
        zoneId:       zoneId || '',
        fromEvent:    fromEvent || false,
        isSimulation: isSimulation || false,
        evPayload:    ev ? (ev.payload    || '') : '',
        evEventType:  ev ? (ev.eventType  || '') : '',
        evVehicleId:  ev ? (ev.vehicleId  || '') : '',
        evDeviceId:   ev ? (ev.deviceId   || '') : '',
        evHighwayId:  ev ? (ev.highwayId  || '') : '',
        evLatitude:   ev ? (ev.latitude   || null) : null,
        evLongitude:  ev ? (ev.longitude  || null) : null,
        evCreatedDate:ev ? (ev.createdDate|| '') : '',
        evZoneId:     ev ? (ev.zoneId     || '') : ''
    };
    scene3d.add(group);
    vehicles3d.push(group);
    return group;
}

// ── Animation loop ───────────────────────────────────────────────────────────

function animate3d() {
    requestAnimationFrame(animate3d);

    vehicles3d.forEach(function(v) {
        // When paused: only simulation vehicles keep moving
        var canMove = !animationPaused || v.userData.isSimulation;
        if (!canMove) return;

        // When zone filtered: dim ambient vehicles not from that zone
        if (selectedZoneId && !v.userData.fromEvent) {
            v.traverse(function(c) {
                if (c.isMesh && c.material && c.material.color) {
                    c.material.transparent = true;
                    c.material.opacity     = 0.25;
                }
            });
        } else if (!v.userData._opacityReset) {
            v.userData._opacityReset = true;
            v.traverse(function(c) {
                if (c.isMesh && c.material) {
                    c.material.transparent = false;
                    c.material.opacity     = 1;
                }
            });
        }

        v.position.z += v.userData.dir * v.userData.speed * speedMult;
        if (v.position.z >  42) { v.position.z = -42; pushFeed3d(v, false, null, v.userData.isSimulation); }
        if (v.position.z < -42) { v.position.z =  42; pushFeed3d(v, false, null, v.userData.isSimulation); }
    });

    // Maintain ambient density only when live (not paused)
    if (!animationPaused) {
        var ambient = vehicles3d.filter(function(v) { return !v.userData.fromEvent; });
        while (ambient.length < density) {
            var s = spawnV(null, false, '');
            ambient.push(s);
        }
        // Trim excess
        while (vehicles3d.length > density + 25) scene3d.remove(vehicles3d.shift());
    }

    renderer3d.render(scene3d, camera3d);
}

// ── Live event polling ───────────────────────────────────────────────────────

var lastPollTime    = new Date().toISOString();
var lastSimPollTime = new Date().toISOString();
var feedItems3d     = [];
var liveEventInterval = null;
var simEventInterval  = null;

function startEventPolling() {
    liveEventInterval = setInterval(pollLiveEvents, 3000);
}

function pollLiveEvents() {
    var url = '/api/events/live?highwayId=' + encodeURIComponent(highwayId) +
              '&since=' + encodeURIComponent(lastPollTime);
    if (selectedZoneId) url += '&zoneId=' + encodeURIComponent(selectedZoneId);

    fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.events || !data.events.length) return;
            lastPollTime = data.serverTime;
            data.events.forEach(function(ev) {
                var spec = vehicleGetRandom(ev.vehicleType || null);
                var grp  = spawnV(spec, true, ev.zoneId || selectedZoneId || '', false, ev);
                if (ev.speedMph) grp.userData.speed = ev.speedMph * 0.012;
                // Reset opacity so event vehicles are always bright
                grp.userData._opacityReset = false;
                pushFeed3d(grp, true, ev, false);
            });
        })
        .catch(function() {});
}

// ── Simulation-only polling (used when paused) ───────────────────────────────

function pollSimulationEvents() {
    var url = '/api/events/simulation?highwayId=' + encodeURIComponent(highwayId) +
              '&since=' + encodeURIComponent(lastSimPollTime);
    if (selectedZoneId) url += '&zoneId=' + encodeURIComponent(selectedZoneId);

    fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.events || !data.events.length) return;
            lastSimPollTime = data.serverTime;
            data.events.forEach(function(ev) {
                var spec = vehicleGetRandom(ev.vehicleType || null);
                var grp  = spawnV(spec, true, ev.zoneId || selectedZoneId || '', true, ev);
                if (ev.speedMph) grp.userData.speed = ev.speedMph * 0.012;
                grp.userData._opacityReset = false;
                pushFeed3d(grp, true, ev, true);
            });
        })
        .catch(function() {});
}

// ── Feed rendering ───────────────────────────────────────────────────────────

function pushFeed3d(v, fromInput, ev, isSimulation) {
    var evType = (ev && ev.eventType) ? ev.eventType : 'detection';
    var spd    = (ev && ev.speedMph)  ? Math.round(ev.speedMph) : Math.round((25 + Math.random() * 55) * speedMult);
    feedItems3d.unshift({
        icon:         v.userData.icon  || '🚗',
        make:         v.userData.make  || '',
        model:        v.userData.model || '',
        eventType:    evType,
        spd:          spd,
        dir:          v.userData.cardinal || (v.userData.lane < 0 ? 'N' : 'S'),
        zoneId:       v.userData.zoneId || '',
        time:         new Date().toLocaleTimeString(),
        fromInput:    fromInput || false,
        isSimulation: isSimulation || v.userData.isSimulation || false
    });
    if (feedItems3d.length > 30) feedItems3d.length = 30;
    renderFeed3d();
}

// ── Direction label helper ────────────────────────────────────────────────────
function dirLabel(d) {
    return d === 'N' ? '↑ Northbound' : d === 'S' ? '↓ Southbound'
         : d === 'E' ? '→ Eastbound'  : d === 'W' ? '← Westbound'
         : d || '—';
}

// ── Event type color map ──────────────────────────────────────────────────────
var FEED_EVENT_COLORS = {
    detection:'#22c55e', merge:'#3b82f6', conflict:'#ef4444',
    speeding:'#f59e0b',  fault:'#8b5cf6',  ambient:'#64748b'
};

// ── Load persisted simulated records into 3D scene ───────────────────────────
function loadSceneFromDB() {
    var url = '/api/events/scene?limit=100&highwayId=' + encodeURIComponent(highwayId);
    if (selectedZoneId) url += '&zoneId=' + encodeURIComponent(selectedZoneId);
    fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.events || !data.events.length) {
                var feed = document.getElementById('trafficFeed');
                if (feed) feed.innerHTML = '<p class="text-muted small p-2">No saved simulation records yet. Run a simulation first.</p>';
                return;
            }
            // Clear current vehicles
            if (vehicles3d) { vehicles3d.forEach(function(v) { scene3d.remove(v); }); vehicles3d.length = 0; }
            feedItems3d.length = 0;
            // Stagger spawn so vehicles appear animated
            data.events.forEach(function(ev, i) {
                setTimeout(function() {
                    var spec = vehicleGetRandom(ev.vehicleType || null);
                    var grp  = spawnV(spec, true, ev.zoneId || '', true, ev);
                    pushFeed3d(grp, true, ev, true);
                }, i * 80);
            });
        })
        .catch(function(e) { console.error('loadSceneFromDB error', e); });
}

function renderFeed3d() {
    var feed = document.getElementById('trafficFeed');
    feed.innerHTML = feedItems3d.map(function(f) {
        var ec = FEED_EVENT_COLORS[f.eventType] || '#64748b';
        var inputTag = f.isSimulation
            ? '<span class="badge ms-1" style="font-size:.58rem;vertical-align:middle;background:#f59e0b;color:#000;font-weight:700"><i class="bi bi-cpu me-1"></i>SIM</span>'
            : (f.fromInput
                ? '<span class="badge bg-warning text-dark ms-1" style="font-size:.58rem;vertical-align:middle">DATA INPUT</span>'
                : '');
        // Show zone indicator when showing all zones
        var zoneTag = (!selectedZoneId && f.zoneId)
            ? '<span class="badge bg-secondary ms-1" style="font-size:.58rem;vertical-align:middle">' + f.zoneId + '</span>'
            : '';
        return '<div class="mss-list-item" style="padding:.35rem .75rem">' +
            '<div class="d-flex justify-content-between align-items-center">' +
            '<span style="font-size:.82rem">' + f.icon + ' <span class="fw-semibold">' + f.make + '</span> ' + f.model + inputTag + zoneTag + '</span>' +
            '<span class="font-monospace text-muted" style="font-size:.6rem">' + f.time + '</span>' +
            '</div>' +
            '<div class="d-flex gap-2 align-items-center mt-1">' +
            '<span class="fw-bold" style="color:' + ec + ';font-size:.74rem">' + f.eventType.toUpperCase() + '</span>' +
            '<span class="text-muted" style="font-size:.74rem">' + dirLabel(f.dir) + ' · ' + f.spd + ' mph</span>' +
            '</div>' +
            '</div>';
    }).join('');
}

// ── Vehicle click-to-inspect ─────────────────────────────────────────────────

function clearVehicleHighlight(v) {
    if (!v) return;
    v.traverse(function(c) {
        if (c.isMesh && c.material && c.material.emissive) {
            c.material.emissive.setHex(0x000000);
            c.material.emissiveIntensity = 0;
        }
    });
}

function closeVehicleDetail() {
    clearVehicleHighlight(selectedVehicle3d);
    selectedVehicle3d = null;
    var panel = document.getElementById('vehicleDetailPanel');
    if (panel) panel.style.display = 'none';
}

function vdSwitchTab(tab) {
    document.getElementById('vdBodyFmt').style.display = tab === 'fmt' ? '' : 'none';
    document.getElementById('vdBodyRaw').style.display = tab === 'raw' ? '' : 'none';
    document.getElementById('vdTabFmt').style.background = tab === 'fmt' ? 'rgba(59,130,246,.18)' : 'transparent';
    document.getElementById('vdTabRaw').style.background = tab === 'raw' ? 'rgba(59,130,246,.18)' : 'transparent';
    document.getElementById('vdTabFmt').style.color = tab === 'fmt' ? '#60a5fa' : '#64748b';
    document.getElementById('vdTabRaw').style.color = tab === 'raw' ? '#60a5fa' : '#64748b';
}

function showVehicleDetail(v, cx, cy) {
    if (selectedVehicle3d && selectedVehicle3d !== v) clearVehicleHighlight(selectedVehicle3d);
    selectedVehicle3d = v;

    // Amber emissive highlight on selected vehicle
    v.traverse(function(c) {
        if (c.isMesh && c.material && c.material.emissive) {
            c.material.emissive.setHex(0xf59e0b);
            c.material.emissiveIntensity = 0.55;
        }
    });

    var ud = v.userData;
    var srcTag = ud.isSimulation
        ? '<span style="background:#f59e0b;color:#000;padding:1px 6px;border-radius:3px;font-size:.62rem;font-weight:700;margin-left:4px">SIM</span>'
        : (ud.fromEvent
            ? '<span style="background:#22c55e;color:#000;padding:1px 6px;border-radius:3px;font-size:.62rem;font-weight:700;margin-left:4px">LIVE</span>'
            : '<span style="background:#475569;color:#fff;padding:1px 6px;border-radius:3px;font-size:.62rem;font-weight:700;margin-left:4px">AMBIENT</span>');
    var cardinal3d = ud.cardinal || (ud.lane < 0 ? 'N' : 'S');
    var dirLabel3d = cardinal3d === 'N' ? 'Northbound (↑)' : cardinal3d === 'S' ? 'Southbound (↓)'
                   : cardinal3d === 'E' ? 'Eastbound (→)'  : cardinal3d === 'W' ? 'Westbound (←)' : '—';
    var spdMph   = Math.round(ud.speed / 0.012);

    document.getElementById('vdTitle').innerHTML = (ud.icon || '🚗') + ' ' +
        (ud.make || 'Vehicle') + ' ' + (ud.model || '') + srcTag;

    // ── Formatted tab ──
    var rows = [
        ['Type',       ud.type         || '—'],
        ['Make/Model', (ud.make || '—') + ' ' + (ud.model || '')],
        ['Direction',  dirLabel3d],
        ['Speed',      spdMph + ' mph'],
        ['Event Type', ud.evEventType  || (ud.fromEvent ? '—' : 'ambient fill')],
        ['Zone',       ud.evZoneId || ud.zoneId || '—'],
        ['Highway',    ud.evHighwayId  || highwayId || '—'],
        ['Vehicle ID', ud.evVehicleId  || '—'],
        ['Device ID',  ud.evDeviceId   || '—'],
    ];
    if (ud.evLatitude)    rows.push(['Latitude',  ud.evLatitude]);
    if (ud.evLongitude)   rows.push(['Longitude', ud.evLongitude]);
    if (ud.evCreatedDate) rows.push(['Timestamp', new Date(ud.evCreatedDate).toLocaleString()]);

    document.getElementById('vdBodyFmt').innerHTML =
        '<table style="width:100%;border-collapse:collapse">' +
        rows.map(function(r) {
            return '<tr>' +
                '<td style="color:#64748b;padding:3px 8px 3px 0;width:88px;vertical-align:top;' +
                    'font-size:.7rem">' + r[0] + '</td>' +
                '<td style="color:#e2e8f0;padding:3px 0;font-weight:500;font-size:.72rem">' +
                    r[1] + '</td></tr>';
        }).join('') + '</table>';

    // ── Raw JSON tab ──
    var rawContent = '(ambient vehicle — no event record)';
    if (ud.evPayload) {
        try { rawContent = JSON.stringify(JSON.parse(ud.evPayload), null, 2); }
        catch(e) { rawContent = ud.evPayload; }
    }
    document.getElementById('vdRawPre').textContent = rawContent;

    vdSwitchTab('fmt');

    // Position panel — clamped inside canvas container
    var panel     = document.getElementById('vehicleDetailPanel');
    var container = document.getElementById('scene3dContainer');
    panel.style.display = '';
    var rect   = container.getBoundingClientRect();
    var pw     = 300, ph = panel.offsetHeight || 320;
    var px     = (cx - rect.left) + 14;
    var py     = (cy - rect.top)  + 14;
    if (px + pw > container.clientWidth  - 4) px = (cx - rect.left) - pw - 14;
    if (py + ph > container.clientHeight - 4) py = (cy - rect.top)  - ph - 14;
    panel.style.left = Math.max(4, px) + 'px';
    panel.style.top  = Math.max(4, py) + 'px';
}

// ── Cross-tab simulation sync ─────────────────────────────────────────────────
(function() {
    function onSimStateChange(simStarted) {
        if (!scene3dInitialized) return;
        if (simStarted && !animationPaused)  toggleAnimation();
        if (!simStarted && animationPaused)  toggleAnimation();
    }
    if (typeof BroadcastChannel !== 'undefined') {
        var bc = new BroadcastChannel('eyeways_sim');
        bc.onmessage = function(e) {
            if (!e.data || !e.data.type) return;
            onSimStateChange(e.data.type === 'sim_started');
        };
    }
    window.addEventListener('storage', function(e) {
        if (e.key === 'eyeways_sim_active') onSimStateChange(e.newValue === 'true');
    });
})();

// ── 5-min countdown ──────────────────────────────────────────────────────────
var countdown = 300;
setInterval(function() {
    countdown--;
    if (countdown <= 0) { countdown = 300; loadSegments(); }
    var m = Math.floor(countdown / 60), s = countdown % 60;
    document.getElementById('mapRefreshTimer').textContent =
        'Refreshes in ' + m + ':' + (s < 10 ? '0' : '') + s;
}, 1000);
</script>
}
