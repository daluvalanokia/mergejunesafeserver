@model EyewaysMergeSafeServer.ViewModels.Traffic3DViewModel
@{ ViewData["Title"] = "3D Traffic"; ViewBag.Highways = Model.Highways; ViewBag.SelectedHighwayId = Model.SelectedHighwayId; }
@{
    var zones   = Model.Zones;
    var sensors = Model.Sensors;
    var servers = Model.SwitchServers;
}

<div class="mss-page-header">
    <div><h2 class="mss-page-title">3D Traffic Visualization</h2><p class="mss-page-sub">Highway map with Leaflet overlays and Three.js Scene3D</p></div>
    <div class="d-flex gap-2">
        <button id="btnMap" class="btn btn-primary btn-sm" onclick="setMode('map')"><i class="bi bi-map me-1"></i>Map</button>
        <button id="btn3d"  class="btn btn-outline-secondary btn-sm" onclick="setMode('3d')"><i class="bi bi-badge-3d me-1"></i>3D Scene</button>
    </div>
</div>

<div class="row g-3">
    <!-- ── Left: map / 3D canvas ─────────────────────────────────────────── -->
    <div class="col-lg-9">
        <div id="mapPanel" class="mss-card">
            <div class="mss-card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-map me-1"></i> Highway Map</span>
                <div class="d-flex align-items-center gap-2">
                    <span id="mapZoneLabel" class="badge bg-primary" style="display:none"></span>
                    <span class="text-muted small" id="mapRefreshTimer">Refreshes in 5:00</span>
                </div>
            </div>
            <div id="leafletMap" style="height:500px;border-radius:0 0 12px 12px;"></div>
        </div>

        <div id="scene3dPanel" class="mss-card" style="display:none">
            <div class="mss-card-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <span><i class="bi bi-badge-3d me-1"></i> Scene3D — Three.js WebGL</span>
                    <span id="scene3dZoneLabel" class="badge bg-primary" style="display:none"></span>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <button id="btnAnimToggle" class="btn btn-outline-warning btn-sm" onclick="toggleAnimation()" style="display:none">
                        <i class="bi bi-pause-fill me-1"></i>Pause
                    </button>
                    <button id="btnLoadScene" class="btn btn-outline-info btn-sm" onclick="loadSceneFromDB()" style="display:none" title="Load saved simulation records into 3D scene">
                        <i class="bi bi-cloud-download me-1"></i>Load Saved
                    </button>
                    <a href="/Vehicles" class="btn btn-outline-secondary btn-sm"><i class="bi bi-car-front me-1"></i>Vehicle Registry</a>
                </div>
            </div>
            <div id="scene3dContainer" style="width:100%;height:500px;border-radius:0 0 12px 12px;overflow:hidden;position:relative;">
                <!-- Zone overlay inside 3D canvas -->
                <div id="zoneOverlay" style="display:none;position:absolute;top:10px;left:10px;z-index:10;
                     background:rgba(10,15,26,.75);backdrop-filter:blur(4px);border:1px solid rgba(255,255,255,.12);
                     border-radius:8px;padding:6px 12px;pointer-events:none">
                    <span class="text-muted" style="font-size:.68rem">FILTERING</span><br>
                    <span id="overlayZoneName" class="fw-semibold" style="font-size:.85rem;color:#f59e0b"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Right: sidebar ────────────────────────────────────────────────── -->
    <div class="col-lg-3">

        <!-- Zones list -->
        <div class="mss-card mb-3">
            <div class="mss-card-header"><i class="bi bi-diagram-2 me-1"></i> Zones</div>
            <div class="mss-card-body p-0" style="max-height:180px;overflow-y:auto">
                @foreach (var z in zones)
                {
                    <div class="mss-list-item d-flex justify-content-between align-items-center zone-list-item"
                         data-zone-id="@z.ZoneId" style="cursor:pointer"
                         onclick="selectZone('@z.ZoneId')" title="Filter to @z.ZoneName">
                        <span class="small">@z.ZoneName</span>
                        <span class="mss-badge mss-badge--@z.Status">@z.Status</span>
                    </div>
                }
                @if (!zones.Any())
                { <p class="text-muted small p-2">No zones.</p> }
            </div>
        </div>

        <!-- Controls (camera / speed / density / zone filter) -->
        <div class="mss-card mb-3">
            <div class="mss-card-header"><i class="bi bi-sliders me-1"></i> Controls</div>
            <div class="mss-card-body">
                <label class="form-label small">Camera Angle</label>
                <input type="range" class="form-range mb-2" id="camAngle" min="10" max="80" step="5" value="45" oninput="setCamAngle(this.value)" />
                <label class="form-label small">Speed Multiplier</label>
                <input type="range" class="form-range mb-2" id="speedMult" min="0.5" max="5" step="0.5" value="1" oninput="setSpeedMult(this.value)" />
                <label class="form-label small">Vehicle Density</label>
                <input type="range" class="form-range mb-3" id="density" min="3" max="30" step="1" value="10" oninput="setDensity(this.value)" />

                <hr class="border-secondary my-0 mb-3" />

                <label class="form-label small d-flex justify-content-between">
                    <span><i class="bi bi-funnel me-1"></i>Zone / Server Filter</span>
                    <button class="btn btn-link btn-sm p-0 text-muted" style="font-size:.7rem" onclick="selectZone('')">Clear</button>
                </label>
                <select class="form-select form-select-sm" id="zoneFilterSelect"
                        onchange="selectZone(this.value)"
                        style="background:#0f1624;border-color:rgba(255,255,255,.18);color:#e2e8f0">
                    <option value="">All Zones</option>
                    @foreach (var z in zones)
                    {
                        <option value="@z.ZoneId">@z.ZoneName</option>
                    }
                </select>

                @if (servers.Any())
                {
                    <div class="mt-2">
                        <label class="form-label small"><i class="bi bi-hdd-network me-1"></i>Switch Server</label>
                        <select class="form-select form-select-sm" id="serverFilterSelect"
                                onchange="selectZoneByServer(this.value)"
                                style="background:#0f1624;border-color:rgba(255,255,255,.18);color:#e2e8f0">
                            <option value="">All Servers</option>
                            @foreach (var s in servers)
                            {
                                <option value="@s.ZoneId" data-server-id="@s.ServerId">@s.ServerName (@s.ZoneId)</option>
                            }
                        </select>
                    </div>
                }
            </div>
        </div>

        <!-- Zone detail panel (visible when a zone is selected) -->
        <div class="mss-card mb-3" id="zoneDetailCard" style="display:none">
            <div class="mss-card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-hdd-network me-1"></i> <span id="zoneDetailTitle">Zone Servers</span></span>
                <span id="zoneDetailBadge" class="mss-badge"></span>
            </div>
            <div class="mss-card-body p-0" id="zoneServerList" style="max-height:200px;overflow-y:auto"></div>
        </div>

        <!-- Live feed -->
        <div class="mss-card">
            <div class="mss-card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-activity me-1"></i> <span id="feedTitle">Live Feed</span>
                    <span id="simModeBadge" style="display:none;font-size:.58rem;vertical-align:middle;margin-left:4px;background:#f59e0b;color:#000;padding:1px 5px;border-radius:4px;font-weight:700">
                        <i class="bi bi-cpu me-1"></i>SIM
                    </span>
                </span>
                <span id="livePulseBadge" class="mss-badge mss-badge--active" style="animation:pulse 1s infinite">LIVE</span>
            </div>
            <div class="mss-card-body p-0" id="trafficFeed" style="max-height:260px;overflow-y:auto">
                <p class="text-muted small p-2">Switch to 3D Scene to start feed…</p>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<style>
.mss-zone-tooltip{background:rgba(10,15,26,.9)!important;border:1px solid rgba(255,255,255,.2)!important;color:#e2e8f0!important;font-size:.67rem!important;font-weight:700!important;box-shadow:none!important;padding:2px 8px!important;white-space:nowrap!important;}
.mss-zone-tooltip::before{border-top-color:rgba(255,255,255,.2)!important;}
</style>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha384-sHL9NAb7lN7rfvG5lfHpm643Xkcjzp4jFvuavGOndn6pjVqS6ny56CAt3nsEVT4H"
      crossorigin="anonymous" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha384-cxOPjt7s7Iz04uaHJceBmS+qpjv2JkIHNVcuOrM+YHwZOmJGBXI00mdUXEq65HTH"
        crossorigin="anonymous"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"
        integrity="sha384-9EQoUIJYrv09/oYhSxnw1VpLcfPw3BM9dE7+D/3wGUPeLLa7F9Z6OAoD+i/M6FK9"
        crossorigin="anonymous"></script>
<script src="~/js/vehicleScene.js"></script>
<script>
// ═══════════════════════════════════════════════════════════════════════════
// Traffic3D — unified event loop
//   • Live mode  : polls /api/events/live every 3s (ALL event types)
//   • Sim mode   : snapshot load from /api/events/scene on entry,
//                  then delta-polls /api/events/simulation every 3s
//                  while the DataInputFormats tab keeps generating data
//   • Cross-tab  : BroadcastChannel + localStorage keep the two tabs synced
//   • No doubles : seenEventIds Set prevents re-rendering the same event
// ═══════════════════════════════════════════════════════════════════════════

// ── Server-side data ─────────────────────────────────────────────────────
var fromSimPage = (new URLSearchParams(window.location.search)).get('from') === 'sim';
var highwayId   = '@(Model.SelectedHighwayId ?? "")';
// Prefer URL-supplied highway over localStorage
(function() {
    var urlHw = (new URLSearchParams(window.location.search)).get('highwayId');
    if (urlHw) highwayId = urlHw;
    else {
        try { var lsHw = localStorage.getItem('eyeways_sim_highway'); if (lsHw) highwayId = lsHw; } catch(e) {}
    }
})();

var sensorData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    sensors.Where(s => s.Latitude.HasValue && s.Longitude.HasValue)
           .Select(s => new { s.DeviceName, s.DeviceType, s.Status, lat = s.Latitude, lon = s.Longitude })));

var zoneData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    zones.Where(z => z.Latitude.HasValue && z.Longitude.HasValue)
         .Select(z => new {
             zoneId   = z.ZoneId,
             zoneName = z.ZoneName,
             status   = z.Status,
             lat      = z.Latitude,
             lon      = z.Longitude,
             r        = z.GeofenceRadius
         })));

var serversByZone = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    servers.GroupBy(s => s.ZoneId ?? "")
           .ToDictionary(
               g => g.Key,
               g => g.Select(s => new {
                   serverId   = s.ServerId,
                   serverName = s.ServerName,
                   ipAddress  = s.IpAddress,
                   port       = s.Port,
                   status     = s.Status
               }).ToList()
           )));

// ── State ────────────────────────────────────────────────────────────────
var selectedZoneId    = '';
var animationPaused   = false;   // true = sim mode, false = live mode
var scene3dInitialized = false;

var lastPollTime      = new Date(Date.now() - 30000).toISOString();  // live cursor
var lastSimPollTime   = new Date().toISOString();                     // sim delta cursor
var sceneLoadPending  = false;   // guard: prevent concurrent loadSceneFromDB calls
var seenEventIds      = new Set(); // dedup guard across all polls
var feedItems3d       = [];

var liveEventInterval = null;
var simEventInterval  = null;

// ── Zone selection ───────────────────────────────────────────────────────
function selectZone(zoneId) {
    selectedZoneId = zoneId || '';
    document.getElementById('zoneFilterSelect').value = selectedZoneId;
    var ss = document.getElementById('serverFilterSelect');
    if (ss) ss.value = selectedZoneId ? selectedZoneId : '';

    document.querySelectorAll('.zone-list-item').forEach(function(el) {
        var active = el.dataset.zoneId === selectedZoneId;
        el.style.background  = active ? 'rgba(59,130,246,.15)' : '';
        el.style.borderLeft  = active ? '3px solid #3b82f6'    : '3px solid transparent';
        el.style.paddingLeft = active ? '9px'                  : '';
    });

    updateMapHighlight(selectedZoneId);
    updateZoneDetailPanel(selectedZoneId);
    updateFeedTitle(selectedZoneId);
    updateSceneZoneLabel(selectedZoneId);

    // Refresh feed immediately for the new zone
    if (scene3dInitialized) {
        if (animationPaused) {
            // Reload sim scene for this zone
            seenEventIds.clear();
            loadSceneFromDB();
        } else {
            lastPollTime = new Date(Date.now() - 30000).toISOString();
            pollLiveEvents();
        }
    }
}

function selectZoneByServer(zoneId) { setMode('map'); selectZone(zoneId); }

// ── Leaflet map ──────────────────────────────────────────────────────────
var mapCenter = zoneData.length > 0 ? [zoneData[0].lat, zoneData[0].lon] : [32.7767, -96.7970];
var map = L.map('leafletMap').setView(mapCenter, 10);
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', { attribution:'© OSM, CARTO' }).addTo(map);

sensorData.forEach(function(s) {
    var color = {camera:'#3b82f6',lidar:'#a855f7',radar:'#f59e0b','vehicle tag reader':'#22c55e'}[s.deviceType] || '#fff';
    L.circleMarker([s.lat, s.lon], {radius:5, color:color, fillColor:color, fillOpacity:0.9})
        .bindPopup('<b>'+s.deviceName+'</b><br>'+s.deviceType+'<br>'+s.status).addTo(map);
});
if (zoneData.length > 1) {
    L.polyline(zoneData.map(function(z){ return [z.lat, z.lon]; }),
        { color:'#3b82f6', weight:4, opacity:0.42, dashArray:'10 6' }).addTo(map);
}

var mapZoneRefs = [];
zoneData.forEach(function(z) {
    var base = z.status === 'fault' ? '#ef4444' : '#22c55e';
    var circle = L.circle([z.lat, z.lon], {radius: z.r || 500, color: base, fillColor: base, fillOpacity: 0.12, weight: 2}).addTo(map);
    var marker = L.circleMarker([z.lat, z.lon], {radius:10, color:base, fillColor:base, fillOpacity:0.95, weight:2})
        .bindPopup('<div style="min-width:150px"><b style="font-size:.85rem">'+z.zoneName+'</b>'+
            ' <span style="font-size:.7rem;color:'+base+'">● '+z.status+'</span>'+
            '<br><code style="font-size:.68rem;color:#94a3b8">'+z.zoneId+'</code>'+
            '<br><a href="#" onclick="selectZone(\''+z.zoneId+'\');return false;" style="font-size:.75rem;color:#60a5fa">Filter to this zone →</a></div>')
        .bindTooltip(z.zoneName, {permanent:true,direction:'top',offset:[0,-14],className:'mss-zone-tooltip'})
        .on('click', function() { selectZone(z.zoneId); })
        .addTo(map);
    mapZoneRefs.push({zoneId:z.zoneId,zoneName:z.zoneName,circle:circle,marker:marker,base:base,lat:z.lat,lon:z.lon});
});

function updateMapHighlight(zoneId) {
    mapZoneRefs.forEach(function(ref) {
        var sel = zoneId && ref.zoneId === zoneId;
        ref.circle.setStyle({color:sel?'#f59e0b':ref.base,fillOpacity:sel?0.22:0.1,weight:sel?3:1});
        ref.marker.setStyle({color:sel?'#f59e0b':ref.base,fillColor:sel?'#f59e0b':ref.base,radius:sel?13:8});
        if (sel) map.flyTo([ref.lat,ref.lon],12,{duration:0.8});
    });
    var label = document.getElementById('mapZoneLabel');
    if (zoneId) {
        var z = zoneData.find(function(z){return z.zoneId===zoneId;});
        label.textContent = z ? z.zoneName : zoneId; label.style.display = '';
    } else { label.style.display='none'; if(zoneData.length) map.flyTo(mapCenter,10,{duration:0.8}); }
}

loadSegments();
function loadSegments() {
    fetch('/Traffic3D/GetTrafficSegments?highwayId='+encodeURIComponent(highwayId))
        .then(function(r){return r.json();}).then(renderSegFeed).catch(function(){renderSegFeed({segments:[]});});
}
function renderSegFeed(data) {
    var segs = data.segments || [];
    if (!segs.length) return;
    var cm = {free:'#22c55e',moderate:'#f59e0b',heavy:'#ef4444'};
    document.getElementById('trafficFeed').innerHTML = segs.map(function(s){
        var c = cm[s.congestion]||'#64748b';
        return '<div class="mss-list-item d-flex justify-content-between align-items-center">'+
               '<span class="small fw-semibold" style="color:'+c+'">'+s.name+'</span>'+
               '<span class="small text-muted">'+s.speedMph+' mph</span></div>';
    }).join('');
}

// ── Zone detail panel ────────────────────────────────────────────────────
function updateZoneDetailPanel(zoneId) {
    var card  = document.getElementById('zoneDetailCard');
    var title = document.getElementById('zoneDetailTitle');
    var badge = document.getElementById('zoneDetailBadge');
    var list  = document.getElementById('zoneServerList');
    if (!zoneId) { card.style.display='none'; return; }
    var zone    = zoneData.find(function(z){return z.zoneId===zoneId;});
    var srvList = serversByZone[zoneId] || [];
    card.style.display=''; title.textContent=zone?zone.zoneName:zoneId;
    badge.textContent=zone?zone.status:''; badge.className='mss-badge mss-badge--'+(zone?zone.status:'active');
    if (!srvList.length) { list.innerHTML='<p class="text-muted small p-2">No servers assigned to this zone.</p>'; return; }
    list.innerHTML = srvList.map(function(s){
        var dot=s.status==='online'?'#22c55e':s.status==='fault'?'#ef4444':'#f59e0b';
        return '<div class="mss-list-item d-flex justify-content-between align-items-center">'+
               '<div><div class="small fw-semibold">'+s.serverName+'</div>'+
               '<div class="font-monospace text-muted" style="font-size:.63rem">'+(s.ipAddress||'—')+':'+s.port+'</div></div>'+
               '<span class="mss-badge mss-badge--'+s.status+'">'+s.status+'</span></div>';
    }).join('');
}
function updateFeedTitle(zoneId) {
    var title=document.getElementById('feedTitle');
    if(zoneId){var z=zoneData.find(function(z){return z.zoneId===zoneId;});title.textContent=(z?z.zoneName:zoneId)+' Feed';}
    else{title.textContent=animationPaused?'Simulation Feed':'Live Feed';}
}
function updateSceneZoneLabel(zoneId) {
    var overlay=document.getElementById('zoneOverlay'),nameEl=document.getElementById('overlayZoneName'),scLabel=document.getElementById('scene3dZoneLabel');
    if(zoneId){var z=zoneData.find(function(z){return z.zoneId===zoneId;});var name=z?z.zoneName:zoneId;
    nameEl.textContent=name;overlay.style.display='';scLabel.textContent=name;scLabel.style.display='';}
    else{overlay.style.display='none';scLabel.style.display='none';}
}

// ── Mode toggle ───────────────────────────────────────────────────────────
function setMode(m) {
    var mapP   = document.getElementById('mapPanel');
    var sc3dP  = document.getElementById('scene3dPanel');
    var btnMap = document.getElementById('btnMap');
    var btn3d  = document.getElementById('btn3d');

    if (m === '3d') {
        mapP.style.display   = 'none';
        sc3dP.style.display  = '';
        btnMap.className     = 'btn btn-outline-secondary btn-sm';
        btn3d.className      = 'btn btn-primary btn-sm';
        if (!scene3dInitialized) {
            initScene3D();
        } else {
            // Already running — restore the correct mode; do NOT disturb sim state
            updateSceneZoneLabel(selectedZoneId);
            if (animationPaused) {
                // Returning to 3D while in sim mode — re-assert sim UI, keep polling
                setSimUI(true);
                if (!simEventInterval) startSimPolling();
            } else {
                // Returning to 3D in live mode — refresh feed
                seenEventIds.clear();
                feedItems3d = [];
                var feedEl = document.getElementById('trafficFeed');
                if (feedEl) feedEl.innerHTML = '<p class="text-muted small p-2">Refreshing…</p>';
                lastPollTime = new Date(Date.now() - 30000).toISOString();
                if (!liveEventInterval) startLivePolling();
                pollLiveEvents();
            }
        }
        updateSceneZoneLabel(selectedZoneId);
    }
    if (m === 'map') {
        mapP.style.display  = '';
        sc3dP.style.display = 'none';
        btnMap.className    = 'btn btn-primary btn-sm';
        btn3d.className     = 'btn btn-outline-secondary btn-sm';
        updateFeedTitle(selectedZoneId);
        if (!feedItems3d.length) loadSegments();
    }
}

// ── Play/pause toggle (sim mode on/off) ───────────────────────────────────
function toggleAnimation() {
    closeVehicleDetail();
    if (!animationPaused) enterSimMode();
    else exitSimMode();
}

// ── Three.js scene ────────────────────────────────────────────────────────
var speedMult=1, density=10, camAngleVal=45;
var renderer3d, camera3d, scene3d, vehicles3d=[];
var raycaster3d=null, mouse3d=null, selectedVehicle3d=null;

function setCamAngle(v) {
    camAngleVal=parseFloat(v);
    if(camera3d){var d=35,rad=camAngleVal*Math.PI/180;camera3d.position.set(0,Math.sin(rad)*d,Math.cos(rad)*d);camera3d.lookAt(0,0,0);}
}
function setSpeedMult(v){speedMult=parseFloat(v);}
function setDensity(v){density=parseInt(v);}

function initScene3D() {
    scene3dInitialized = true;
    var container = document.getElementById('scene3dContainer');
    var W = container.clientWidth, H = container.clientHeight;

    scene3d = new THREE.Scene();
    scene3d.background = new THREE.Color(0x0a0f1a);
    scene3d.fog = new THREE.FogExp2(0x0a0f1a, 0.016);

    camera3d = new THREE.PerspectiveCamera(45, W/H, 0.1, 500);
    camera3d.position.set(0, 22, 28); camera3d.lookAt(0,0,0);

    renderer3d = new THREE.WebGLRenderer({antialias:true});
    renderer3d.setSize(W,H); renderer3d.setPixelRatio(window.devicePixelRatio);
    renderer3d.shadowMap.enabled=true;
    container.appendChild(renderer3d.domElement);

    scene3d.add(new THREE.AmbientLight(0x334466,2));
    var dir=new THREE.DirectionalLight(0x8899ff,2.5);
    dir.position.set(10,20,10);dir.castShadow=true;scene3d.add(dir);

    var gnd=new THREE.Mesh(new THREE.PlaneGeometry(120,120),new THREE.MeshLambertMaterial({color:0x050a12}));
    gnd.rotation.x=-Math.PI/2;gnd.receiveShadow=true;scene3d.add(gnd);
    var road=new THREE.Mesh(new THREE.PlaneGeometry(14,80),new THREE.MeshLambertMaterial({color:0x1a2035}));
    road.rotation.x=-Math.PI/2;road.position.y=0.02;road.receiveShadow=true;scene3d.add(road);
    var med=new THREE.Mesh(new THREE.PlaneGeometry(0.4,80),new THREE.MeshLambertMaterial({color:0x2a3a55}));
    med.rotation.x=-Math.PI/2;med.position.y=0.025;scene3d.add(med);
    for(var zi=-36;zi<37;zi+=6){[-5,-3,3,5].forEach(function(xl){
        var lm=new THREE.Mesh(new THREE.PlaneGeometry(0.12,3),new THREE.MeshBasicMaterial({color:Math.abs(xl)===5?0xffffff:0xffff00}));
        lm.rotation.x=-Math.PI/2;lm.position.set(xl,0.03,zi);scene3d.add(lm);
    });}
    [-7.2,7.2].forEach(function(cx){
        var curb=new THREE.Mesh(new THREE.BoxGeometry(0.25,0.12,80),new THREE.MeshLambertMaterial({color:0x2c3a52}));
        curb.position.set(cx,0.06,0);scene3d.add(curb);
    });

    vehicles3d=[];
    for(var vi=0;vi<density;vi++) spawnV();
    animate3d();

    // Start live polling
    startLivePolling();

    var tb=document.getElementById('btnAnimToggle');
    if(tb){tb.style.display='';animationPaused=false;}
    var lsb=document.getElementById('btnLoadScene');
    if(lsb) lsb.style.display='';

    // Auto-enter sim mode if we arrived from the simulation page
    if (fromSimPage || getSimActive()) {
        setTimeout(enterSimMode, 800);
    }

    // Click-to-inspect
    raycaster3d=new THREE.Raycaster();mouse3d=new THREE.Vector2();
    var vpanel=document.createElement('div');
    vpanel.id='vehicleDetailPanel';
    vpanel.style.cssText='display:none;position:absolute;top:0;left:0;z-index:20;width:300px;'+
        'background:rgba(8,12,24,.97);border:1px solid rgba(255,255,255,.14);'+
        'border-radius:10px;backdrop-filter:blur(8px);box-shadow:0 8px 32px rgba(0,0,0,.6);overflow:hidden;';
    vpanel.innerHTML=
        '<div style="padding:9px 12px;border-bottom:1px solid rgba(255,255,255,.09);display:flex;justify-content:space-between;align-items:center">'+
        '<span id="vdTitle" style="font-size:.8rem;font-weight:700;color:#e2e8f0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:250px"></span>'+
        '<button id="vdClose" style="background:none;border:none;color:#94a3b8;font-size:1.1rem;cursor:pointer;line-height:1;padding:0 2px;flex-shrink:0">×</button></div>'+
        '<div style="display:flex;border-bottom:1px solid rgba(255,255,255,.07)">'+
        '<button id="vdTabFmt" onclick="vdSwitchTab(\'fmt\')" style="flex:1;padding:5px;font-size:.7rem;font-weight:600;background:rgba(59,130,246,.18);border:none;color:#60a5fa;cursor:pointer">Formatted</button>'+
        '<button id="vdTabRaw" onclick="vdSwitchTab(\'raw\')" style="flex:1;padding:5px;font-size:.7rem;font-weight:600;background:transparent;border:none;color:#64748b;cursor:pointer">Raw JSON</button></div>'+
        '<div id="vdBodyFmt" style="padding:10px 12px;max-height:240px;overflow-y:auto"></div>'+
        '<div id="vdBodyRaw" style="display:none;padding:10px 12px;max-height:240px;overflow-y:auto">'+
        '<pre id="vdRawPre" style="font-size:.6rem;color:#94a3b8;white-space:pre-wrap;word-break:break-all;margin:0;line-height:1.5"></pre></div>';
    container.appendChild(vpanel);
    vpanel.addEventListener('click',function(e){e.stopPropagation();});
    document.getElementById('vdClose').addEventListener('click',closeVehicleDetail);

    container.addEventListener('mousemove',function(e){
        if(!raycaster3d||!camera3d)return;
        var rect=renderer3d.domElement.getBoundingClientRect();
        mouse3d.x=((e.clientX-rect.left)/rect.width)*2-1;
        mouse3d.y=-((e.clientY-rect.top)/rect.height)*2+1;
        raycaster3d.setFromCamera(mouse3d,camera3d);
        container.style.cursor=raycaster3d.intersectObjects(vehicles3d,true).length?'pointer':'';
    });
    container.addEventListener('click',function(e){
        var panel=document.getElementById('vehicleDetailPanel');
        if(panel&&panel.contains(e.target))return;
        if(!raycaster3d||!camera3d)return;
        var rect=renderer3d.domElement.getBoundingClientRect();
        mouse3d.x=((e.clientX-rect.left)/rect.width)*2-1;
        mouse3d.y=-((e.clientY-rect.top)/rect.height)*2+1;
        raycaster3d.setFromCamera(mouse3d,camera3d);
        var hits=raycaster3d.intersectObjects(vehicles3d,true);
        if(!hits.length){closeVehicleDetail();return;}
        var obj=hits[0].object;
        while(obj.parent&&vehicles3d.indexOf(obj)<0)obj=obj.parent;
        if(vehicles3d.indexOf(obj)<0){closeVehicleDetail();return;}
        showVehicleDetail(obj,e.clientX,e.clientY);
    });
    document.addEventListener('keydown',function(e){if(e.key==='Escape')closeVehicleDetail();});
    document.addEventListener('click',function(e){
        var panel=document.getElementById('vehicleDetailPanel');
        if(!panel||panel.style.display==='none')return;
        var cont=document.getElementById('scene3dContainer');
        if(cont&&!cont.contains(e.target))closeVehicleDetail();
    },true);
    window.addEventListener('resize',function(){
        if(!renderer3d)return;
        var W2=container.clientWidth,H2=container.clientHeight;
        renderer3d.setSize(W2,H2);camera3d.aspect=W2/H2;camera3d.updateProjectionMatrix();
    });
}

// ── Vehicle spawning ─────────────────────────────────────────────────────
function spawnV(vSpec, fromEvent, zoneId, isSimulation, ev) {
    if(!vSpec) vSpec=vehicleGetRandom(ev&&ev.vehicleType?ev.vehicleType:null);
    var group=vehicleBuildMesh(vSpec);
    var cardinal=ev&&ev.direction?ev.direction:null;
    var lanePool=cardinal==='N'?[-4,-2]:cardinal==='S'?[2,4]:cardinal==='E'?[1,3]:cardinal==='W'?[-3,-1]:[-4,-2,2,4];
    var lx=lanePool[Math.floor(Math.random()*lanePool.length)]+(Math.random()-.5)*.6;
    group.position.set(lx,0.45,(Math.random()-0.5)*70);
    var goingForward=(lx<0)||(cardinal==='N')||(cardinal==='E');
    group.rotation.y=goingForward?0:Math.PI;
    var spd=ev&&ev.speedMph?ev.speedMph*0.012:(0.05+Math.random()*0.18)*speedMult;
    group.userData={
        speed:spd,forward:goingForward,laneX:lx,
        vehicleType:vSpec.type||'sedan',icon:vSpec.icon||'🚗',
        make:vSpec.make||'',model:vSpec.model||'',
        cardinal:cardinal||(goingForward?'N':'S'),
        zoneId:zoneId||'',isSimulation:!!isSimulation,
        event:ev||null,_opacityReset:false
    };
    vehicles3d.push(group);
    if(scene3d) scene3d.add(group);
    return group;
}

// ── Animation loop ───────────────────────────────────────────────────────
var animFrameId=null;
function animate3d() {
    animFrameId=requestAnimationFrame(animate3d);
    vehicles3d.forEach(function(v) {
        var s=v.userData.speed*speedMult;
        if(v.userData.forward) v.position.z-=s; else v.position.z+=s;
        if(v.position.z< -42) v.position.z=42;
        if(v.position.z>  42) v.position.z=-42;
        if(!v.userData._opacityReset){v.userData._opacityReset=true;}
    });
    if(renderer3d&&scene3d&&camera3d) renderer3d.render(scene3d,camera3d);
}

// ── Live polling (non-sim mode) ──────────────────────────────────────────
function startLivePolling() {
    if(liveEventInterval) return; // already running
    liveEventInterval = setInterval(pollLiveEvents, 3000);
}
function stopLivePolling() {
    if(liveEventInterval){clearInterval(liveEventInterval);liveEventInterval=null;}
}

function pollLiveEvents() {
    var url='/api/events/live?highwayId='+encodeURIComponent(highwayId)+
            '&since='+encodeURIComponent(lastPollTime);
    if(selectedZoneId) url+='&zoneId='+encodeURIComponent(selectedZoneId);
    fetch(url)
        .then(function(r){return r.json();})
        .then(function(data){
            if(!data.events||!data.events.length){return;}
            lastPollTime=data.serverTime;
            data.events.forEach(function(ev){
                if(seenEventIds.has(ev.id))return;
                seenEventIds.add(ev.id);
                var spec=vehicleGetRandom(ev.vehicleType||null);
                var grp=spawnV(spec,true,ev.zoneId||selectedZoneId||'',ev.isSimulated,ev);
                if(ev.speedMph) grp.userData.speed=ev.speedMph*0.012;
                pushFeed3d(grp,true,ev,ev.isSimulated||false);
            });
        }).catch(function(){});
}

// ── Sim mode enter/exit ──────────────────────────────────────────────────
function enterSimMode() {
    if(!scene3dInitialized){setTimeout(enterSimMode,400);return;}
    if(animationPaused) return; // already in sim mode — don't double-enter
    animationPaused=true;

    // Stop live polling
    stopLivePolling();

    // Clear scene
    vehicles3d.forEach(function(v){scene3d.remove(v);});
    vehicles3d.length=0;
    feedItems3d.length=0;
    seenEventIds.clear();

    // Update UI
    var btn=document.getElementById('btnAnimToggle');
    if(btn){btn.innerHTML='<i class="bi bi-play-fill me-1"></i>Resume';btn.className='btn btn-success btn-sm';}
    setSimUI(true);

    // Load scene snapshot then start delta-polling
    // (simEventInterval will NOT be started until loadSceneFromDB completes)
    loadSceneFromDB();
}

function exitSimMode() {
    if(!animationPaused) return; // already in live mode
    animationPaused=false;

    stopSimPolling();
    vehicles3d.forEach(function(v){scene3d.remove(v);});
    vehicles3d.length=0;
    feedItems3d.length=0;
    seenEventIds.clear();

    var btn=document.getElementById('btnAnimToggle');
    if(btn){btn.innerHTML='<i class="bi bi-pause-fill me-1"></i>Pause';btn.className='btn btn-outline-warning btn-sm';}
    setSimUI(false);

    var feedEl=document.getElementById('trafficFeed');
    if(feedEl) feedEl.innerHTML='<p class="text-muted small p-2"><i class="bi bi-arrow-repeat me-2"></i>Resuming live feed…</p>';

    lastPollTime=new Date(Date.now()-30000).toISOString();
    startLivePolling();
    pollLiveEvents();
}

function setSimUI(on) {
    var feedTitle=document.getElementById('feedTitle');
    var simBadge =document.getElementById('simModeBadge');
    var liveBadge=document.getElementById('livePulseBadge');
    if(on){
        if(feedTitle){feedTitle.textContent=selectedZoneId?((zoneData.find(function(z){return z.zoneId===selectedZoneId;})||{}).zoneName||selectedZoneId)+' Sim Feed':'Simulation Feed';feedTitle.style.color='#f59e0b';}
        if(simBadge) simBadge.style.display='';
        if(liveBadge){liveBadge.textContent='SIM ONLY';liveBadge.style.background='#92400e';}
    }else{
        if(feedTitle){feedTitle.textContent='Live Feed';feedTitle.style.color='';}
        if(simBadge) simBadge.style.display='none';
        if(liveBadge){liveBadge.textContent='LIVE';liveBadge.style.background='';}
    }
}

// ── Sim delta-polling (top-up while DataInputFormats tab keeps running) ──
function startSimPolling() {
    if(simEventInterval) return;
    simEventInterval=setInterval(pollSimulationEvents,3000);
}
function stopSimPolling() {
    if(simEventInterval){clearInterval(simEventInterval);simEventInterval=null;}
}

function pollSimulationEvents() {
    var url='/api/events/simulation?highwayId='+encodeURIComponent(highwayId)+
            '&since='+encodeURIComponent(lastSimPollTime);
    if(selectedZoneId) url+='&zoneId='+encodeURIComponent(selectedZoneId);
    fetch(url)
        .then(function(r){return r.json();})
        .then(function(data){
            if(!data.events||!data.events.length){return;}
            lastSimPollTime=data.serverTime;
            data.events.forEach(function(ev){
                if(seenEventIds.has(ev.id))return;
                seenEventIds.add(ev.id);
                var spec=vehicleGetRandom(ev.vehicleType||null);
                var grp=spawnV(spec,true,ev.zoneId||selectedZoneId||'',true,ev);
                if(ev.speedMph) grp.userData.speed=ev.speedMph*0.012;
                grp.userData._opacityReset=false;
                pushFeed3d(grp,true,ev,true);
            });
        }).catch(function(){});
}

// ── Snapshot load (initial scene population) ─────────────────────────────
function loadSceneFromDB() {
    if(sceneLoadPending) return; // prevent concurrent loads
    sceneLoadPending=true;

    var url='/api/events/scene?limit=100&highwayId='+encodeURIComponent(highwayId);
    if(selectedZoneId) url+='&zoneId='+encodeURIComponent(selectedZoneId);

    var feedEl=document.getElementById('trafficFeed');
    if(feedEl) feedEl.innerHTML='<p class="text-muted small p-2"><i class="bi bi-hourglass-split me-2"></i>Loading simulation data…</p>';

    fetch(url)
        .then(function(r){return r.json();})
        .then(function(data){
            sceneLoadPending=false;
            // Clear current vehicles
            vehicles3d.forEach(function(v){scene3d.remove(v);});
            vehicles3d.length=0;
            feedItems3d.length=0;

            if(!data.events||!data.events.length){
                if(feedEl) feedEl.innerHTML='<p class="text-muted small p-2">No saved simulation records yet. Start a simulation on the Data Input Formats tab, then return here.</p>';
                // Still start delta-polling so new events appear as sim runs
                lastSimPollTime=new Date().toISOString();
                startSimPolling();
                return;
            }

            if(feedEl) feedEl.innerHTML='';
            var total=data.events.length;

            // Mark all snapshot events as seen to prevent delta-poll duplicates
            data.events.forEach(function(ev){ seenEventIds.add(ev.id); });

            // Use the server's cursor (newest event timestamp) as our delta-poll start
            // This means only events NEWER than the snapshot will come through delta-poll
            lastSimPollTime = data.cursor || data.events.reduce(function(mx,ev){
                return ev.createdDate > mx ? ev.createdDate : mx;
            }, new Date(0).toISOString());

            // Stagger spawn for animation effect
            data.events.forEach(function(ev,i){
                setTimeout(function(){
                    var spec=vehicleGetRandom(ev.vehicleType||null);
                    var grp=spawnV(spec,true,ev.zoneId||'',true,ev);
                    if(ev.speedMph) grp.userData.speed=ev.speedMph*0.012;
                    pushFeed3d(grp,true,ev,true);
                },i*60);
            });

            // After spawn animation completes, start delta-polling for new events
            setTimeout(function(){
                console.log('[3D] Loaded '+total+' sim records. Poll cursor: '+lastSimPollTime);
                startSimPolling();
            }, total*60+300);
        })
        .catch(function(e){
            sceneLoadPending=false;
            console.error('loadSceneFromDB error',e);
            startSimPolling(); // still poll even if snapshot failed
        });
}

// ── Feed rendering ────────────────────────────────────────────────────────
var FEED_EVENT_COLORS={detection:'#22c55e',merge:'#3b82f6',conflict:'#ef4444',speeding:'#f59e0b',fault:'#8b5cf6',ambient:'#64748b'};

function pushFeed3d(v,fromInput,ev,isSimulation){
    var evType=(ev&&ev.eventType)?ev.eventType:'detection';
    var spd=(ev&&ev.speedMph)?Math.round(ev.speedMph):Math.round((25+Math.random()*55)*speedMult);
    feedItems3d.unshift({
        icon:v.userData.icon||'🚗',make:v.userData.make||'',model:v.userData.model||'',
        eventType:evType,spd:spd,
        dir:v.userData.cardinal||(v.userData.laneX<0?'N':'S'),
        zoneId:v.userData.zoneId||'',
        time:new Date().toLocaleTimeString(),
        fromInput:fromInput||false,
        isSimulation:isSimulation||v.userData.isSimulation||false,
        vehicleType:v.userData.vehicleType||'sedan'
    });
    if(feedItems3d.length>30) feedItems3d.length=30;
    renderFeed3d();
}

function dirLabel(d){return d==='N'?'↑ Northbound':d==='S'?'↓ Southbound':d==='E'?'→ Eastbound':d==='W'?'← Westbound':d||'—';}

function renderFeed3d(){
    var feed=document.getElementById('trafficFeed');
    if(!feed)return;
    feed.innerHTML=feedItems3d.map(function(f){
        var ec=FEED_EVENT_COLORS[f.eventType]||'#64748b';
        var inputTag=f.isSimulation
            ?'<span class="badge ms-1" style="font-size:.58rem;vertical-align:middle;background:#f59e0b;color:#000;font-weight:700"><i class="bi bi-cpu me-1"></i>SIM</span>'
            :(f.fromInput?'<span class="badge bg-warning text-dark ms-1" style="font-size:.58rem;vertical-align:middle">DATA INPUT</span>':'');
        var zoneTag=(!selectedZoneId&&f.zoneId)?'<span class="badge bg-secondary ms-1" style="font-size:.58rem;vertical-align:middle">'+f.zoneId+'</span>':'';
        var typeTag='<span class="badge ms-1" style="font-size:.55rem;vertical-align:middle;background:rgba(255,255,255,.1);color:#94a3b8">'+f.vehicleType+'</span>';
        return '<div class="mss-list-item" style="padding:.35rem .75rem">'+
            '<div class="d-flex justify-content-between align-items-center">'+
            '<span style="font-size:.82rem">'+f.icon+' <span class="fw-semibold">'+f.make+'</span> '+f.model+inputTag+zoneTag+'</span>'+
            '<span class="font-monospace text-muted" style="font-size:.6rem">'+f.time+'</span></div>'+
            '<div class="d-flex gap-2 mt-1" style="font-size:.68rem">'+
            '<span style="color:'+ec+'">●&nbsp;'+f.eventType+'</span>'+
            typeTag+
            '<span class="text-muted">'+f.spd+' mph</span>'+
            '<span class="text-muted ms-auto">'+dirLabel(f.dir)+'</span></div></div>';
    }).join('');
}

// ── Vehicle detail panel ──────────────────────────────────────────────────
function vdSwitchTab(t){
    document.getElementById('vdBodyFmt').style.display=t==='fmt'?'':'none';
    document.getElementById('vdBodyRaw').style.display=t==='raw'?'':'none';
    document.getElementById('vdTabFmt').style.background=t==='fmt'?'rgba(59,130,246,.18)':'transparent';
    document.getElementById('vdTabFmt').style.color=t==='fmt'?'#60a5fa':'#64748b';
    document.getElementById('vdTabRaw').style.background=t==='raw'?'rgba(59,130,246,.18)':'transparent';
    document.getElementById('vdTabRaw').style.color=t==='raw'?'#60a5fa':'#64748b';
}
function closeVehicleDetail(){var p=document.getElementById('vehicleDetailPanel');if(p)p.style.display='none';selectedVehicle3d=null;}

function showVehicleDetail(obj,cx,cy){
    selectedVehicle3d=obj;
    var ev=obj.userData.event;
    var vt=obj.userData.vehicleType||'sedan';
    var make=obj.userData.make||'';
    var model=obj.userData.model||'';
    var simTag=obj.userData.isSimulation?'<span style="background:#f59e0b;color:#000;padding:1px 6px;border-radius:3px;font-size:.65rem;font-weight:700;margin-left:4px">SIM</span>':'';
    document.getElementById('vdTitle').innerHTML='<span style="font-size:1rem">'+obj.userData.icon+'</span>&nbsp;'+make+' '+model+simTag;
    var rows=[
        ['Vehicle Type',vt],
        ['Direction',dirLabel(obj.userData.cardinal)],
        ['Speed',(ev&&ev.speedMph?Math.round(ev.speedMph):Math.round((25+Math.random()*55)))+ ' mph'],
        ['Zone',obj.userData.zoneId||'—'],
        ['Event Type',(ev&&ev.eventType)||'detection'],
        ['Is Simulation',obj.userData.isSimulation?'✅ Yes':'❌ No'],
    ];
    if(ev&&ev.vehicleId) rows.splice(0,0,['Vehicle ID',ev.vehicleId]);
    if(ev&&ev.latitude)  rows.push(['GPS',''+ev.latitude+', '+ev.longitude]);
    document.getElementById('vdBodyFmt').innerHTML=rows.map(function(r){
        return '<div style="display:flex;justify-content:space-between;padding:3px 0;border-bottom:1px solid rgba(255,255,255,.05)">'+
               '<span style="color:#64748b;font-size:.72rem">'+r[0]+'</span>'+
               '<span style="color:#e2e8f0;font-size:.72rem;font-weight:600;text-align:right;max-width:170px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+r[1]+'</span></div>';
    }).join('');
    var rawObj={vehicleId:ev&&ev.vehicleId||null,vehicleType:vt,make:make,model:model,direction:obj.userData.cardinal,speedMph:ev&&ev.speedMph||null,zoneId:obj.userData.zoneId,isSimulation:obj.userData.isSimulation,event:ev};
    document.getElementById('vdRawPre').textContent=JSON.stringify(rawObj,null,2);
    vdSwitchTab('fmt');
    var panel=document.getElementById('vehicleDetailPanel');
    var container=document.getElementById('scene3dContainer');
    panel.style.display='';
    var rect=container.getBoundingClientRect();
    var pw=300,ph=panel.offsetHeight||320;
    var px=(cx-rect.left)+14,py=(cy-rect.top)+14;
    if(px+pw>container.clientWidth-4)  px=(cx-rect.left)-pw-14;
    if(py+ph>container.clientHeight-4) py=(cy-rect.top)-ph-14;
    panel.style.left=Math.max(4,px)+'px';
    panel.style.top=Math.max(4,py)+'px';
}

// ── Cross-tab sim sync (BroadcastChannel + localStorage) ─────────────────
function getSimActive(){
    try{return localStorage.getItem('eyeways_sim_active')==='true';}catch(e){return false;}
}
(function(){
    function onSimStateChange(started,e){
        if(started){
            // Sim started in the other tab
            if(!scene3dInitialized){setMode('3d');setTimeout(enterSimMode,800);}
            else if(!animationPaused){enterSimMode();}
            // If already in sim mode: just let the running delta-poll pick up new events (do nothing)
        }else{
            // Sim stopped broadcast — only auto-exit if it was an explicit user stop
            // (not just a page-unload / tab close on the sim side)
            if(animationPaused && e && e.data && e.data.explicit===true) exitSimMode();
            if(!e || !e.data || e.data.explicit===true){
                try{localStorage.removeItem('eyeways_sim_active');}catch(e2){}
            }
        }
    }
    if(typeof BroadcastChannel!=='undefined'){
        var bc=new BroadcastChannel('eyeways_sim');
        bc.onmessage=function(e){
            if(!e.data||!e.data.type)return;
            onSimStateChange(e.data.type==='sim_started', e);
        };
    }
    window.addEventListener('storage',function(e){
        // localStorage storage events fire when the key is removed (null) — treat that
        // as non-explicit so we don't auto-exit sim mode just because the other tab navigated
        if(e.key==='eyeways_sim_active' && e.newValue==='true') onSimStateChange(true,null);
        // Do not auto-exit on storage removal — only the explicit broadcast does that
    });
})();

