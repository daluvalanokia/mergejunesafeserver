@model EyewaysMergeSafeServer.ViewModels.DataInputFormatsViewModel
@{ ViewData["Title"] = "Data Input Formats"; ViewBag.Highways = null; }
@{
    var tabDefs = new[]{
        ("physical",  "Physical Sensors", "text-primary"),
        ("satellite", "Satellite / GPS",  "text-success"),
        ("telecom",   "Telecom / V2X",    "text-warning"),
        ("tracker",   "Tag Trackers",     "text-purple"),
    };
    var allConfigs   = Model.PhysicalConfigs.Concat(Model.SatelliteConfigs).Concat(Model.TelecomConfigs).Concat(Model.TrackerConfigs).ToList();
    var commonFields = new[]{"vehicle_id","timestamp","speed_mph","latitude","longitude","direction","lane","vehicle_type","event_type","zone_id","highway_id","signal_strength","altitude_ft","heading"};
    var shown = Model.ActiveTab switch {
        "satellite" => Model.SatelliteConfigs,
        "telecom"   => Model.TelecomConfigs,
        "tracker"   => Model.TrackerConfigs,
        _           => Model.PhysicalConfigs
    };
    var isSimTab = Model.ActiveTab == "simulation";
}

<div class="mss-page-header">
    <div><h2 class="mss-page-title">Data Input Formats</h2><p class="mss-page-sub">Configure sensor telemetry ingestion formats and generate test payloads</p></div>
    @if (!isSimTab)
    {
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#fmtModal" onclick="openNew('@Model.ActiveTab')">
            <i class="bi bi-plus me-1"></i>Add Format
        </button>
    }
</div>

<ul class="nav nav-tabs mb-3">
    @foreach (var (type, label, clr) in tabDefs)
    {
        <li class="nav-item">
            <a class="nav-link @(Model.ActiveTab == type ? "active" : "") @clr"
               href="/DataInputFormats?activeTab=@type">@label</a>
        </li>
    }
    <li class="nav-item">
        <a class="nav-link @(isSimTab ? "active" : "") text-info"
           href="/DataInputFormats?activeTab=simulation">
            <i class="bi bi-cpu me-1"></i>Simulation
        </a>
    </li>
</ul>

@if (isSimTab)
{
    <!-- ── Simulation Tab ──────────────────────────────────────────────────── -->
    <div class="row g-3">
        <!-- Left: config -->
        <div class="col-lg-5">
            <div class="mss-card">
                <div class="mss-card-header"><i class="bi bi-cpu me-1"></i> Simulation Configuration</div>
                <div class="mss-card-body">

                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Highway</label>
                        <select class="form-select" id="simHighway" onchange="simFilterDropdowns()">
                            <option value="">All Highways</option>
                            @foreach (var h in Model.Highways)
                            { <option value="@h.HighwayId">@h.Name</option> }
                        </select>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Switch Server</label>
                            <select class="form-select form-select-sm" id="simServer">
                                <option value="">Any Server</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Zone</label>
                            <select class="form-select form-select-sm" id="simZone" onchange="simFilterServers()">
                                <option value="">Any Zone</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Sensor / Source Type</label>
                        <select class="form-select" id="simType">
                            <option value="physical">Physical / Camera</option>
                            <option value="satellite">Satellite / GPS</option>
                            <option value="telecom">Telecom / V2X</option>
                            <option value="tracker">Tag Tracker</option>
                        </select>
                    </div>

                    <div class="row g-2 mb-4">
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Start Delay</label>
                            <select class="form-select" id="simDelay">
                                <option value="0">No delay</option>
                                <option value="1">1 second</option>
                                <option value="2">2 seconds</option>
                                <option value="3">3 seconds</option>
                                <option value="5">5 seconds</option>
                                <option value="10">10 seconds</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Post Interval</label>
                            <select class="form-select" id="simInterval">
                                <option value="10">Every 10 seconds</option>
                                <option value="20">Every 20 seconds</option>
                                <option value="30" selected>Every 30 seconds</option>
                                <option value="40">Every 40 seconds</option>
                                <option value="60">Every 60 seconds</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mb-3">
                        <button id="btnStartSim" class="btn btn-success flex-fill" onclick="startSim()">
                            <i class="bi bi-play-fill me-1"></i>Start Simulation
                        </button>
                        <button id="btnStopSim" class="btn btn-danger flex-fill" onclick="stopSim()" style="display:none">
                            <i class="bi bi-stop-fill me-1"></i>Stop
                        </button>
                    </div>
                    <div class="d-flex gap-2 mb-3">
                        <button id="btnToggle3DPanel" class="btn btn-outline-info btn-sm flex-fill"
                                onclick="toggle3DPanel()" title="Show embedded 3D scene with sim data">
                            <i class="bi bi-badge-3d me-1"></i>3D Scene <i id="icon3DPanel" class="bi bi-chevron-down ms-1"></i>
                        </button>
                        <button class="btn btn-outline-secondary btn-sm flex-fill" onclick="clearSimLog()">
                            <i class="bi bi-trash me-1"></i>Clear Log
                        </button>
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <span id="simStatusDot" class="rounded-circle d-inline-block flex-shrink-0"
                              style="width:9px;height:9px;background:#475569"></span>
                        <span id="simStatus" class="small text-muted">Stopped — ready to simulate</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: live log -->
        <div class="col-lg-7">
            <div class="mss-card" style="height:100%">
                <div class="mss-card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-activity me-1"></i> Simulation Log</span>
                    <div class="d-flex align-items-center gap-2">
                        <span id="simTotalBadge" class="badge bg-secondary">0 posted</span>

                    </div>
                </div>
                <div id="simLog" style="max-height:500px;overflow-y:auto">
                    <p class="text-muted small p-3">Start simulation to see live payloads posted here…</p>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Embedded 3D Scene Panel (expandable) ──────────────────────────── -->
    <div id="simScene3DPanel" style="display:none;margin-top:1rem">
        <div class="mss-card">
            <div class="mss-card-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-badge-3d me-1"></i>
                    <span>3D Traffic Visualization</span>
                    <span class="badge" style="background:#f59e0b;color:#000;font-size:.6rem;font-weight:700">
                        <i class="bi bi-cpu me-1"></i>SIM ONLY
                    </span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span id="sim3dFeedCount" class="badge bg-secondary" style="font-size:.6rem">0 vehicles</span>
                    <button class="btn btn-outline-secondary btn-sm py-0 px-2" style="font-size:.7rem"
                            onclick="toggle3DPanel()" title="Collapse">
                        <i class="bi bi-chevron-up"></i>
                    </button>
                </div>
            </div>
            <div class="row g-0" style="height:420px">
                <!-- Left: mini 3D canvas -->
                <div class="col-lg-8 position-relative" style="height:420px">
                    <div id="simMini3DContainer" style="width:100%;height:100%;border-radius:0 0 0 12px;overflow:hidden;background:#060d1a;position:relative">
                        <canvas id="simMiniCanvas" style="width:100%;height:100%;display:block"></canvas>
                        <!-- loading overlay -->
                        <div id="simMini3DLoader" style="position:absolute;inset:0;display:flex;flex-direction:column;
                             align-items:center;justify-content:center;background:rgba(6,13,26,.92);z-index:5">
                            <div class="spinner-border text-info mb-2" style="width:1.5rem;height:1.5rem"></div>
                            <span class="text-muted small">Initialising 3D scene…</span>
                        </div>
                    </div>
                    <!-- click-to-inspect overlay hint -->
                    <div style="position:absolute;bottom:8px;left:8px;z-index:4;pointer-events:none;
                                font-size:.6rem;color:rgba(255,255,255,.35)">
                        <i class="bi bi-cursor me-1"></i>Click a vehicle to inspect
                    </div>
                </div>
                <!-- Right: feed list -->
                <div class="col-lg-4 d-flex flex-column" style="height:420px;border-left:1px solid rgba(255,255,255,.07)">
                    <div class="px-3 pt-2 pb-1 d-flex justify-content-between align-items-center"
                         style="border-bottom:1px solid rgba(255,255,255,.07)">
                        <span class="small fw-semibold" style="color:#f59e0b">
                            <i class="bi bi-activity me-1"></i>Sim Feed
                        </span>
                        <span class="text-muted" style="font-size:.6rem">click row for details</span>
                    </div>
                    <div id="simMini3DFeed"
                         style="flex:1;overflow-y:auto;font-size:.72rem">
                        <p class="text-muted small p-2" id="simMini3DFeedEmpty">
                            Start the simulation to see events here…
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Feed Event Detail Modal ──────────────────────────────────────── -->
    <div class="modal fade" id="simFeedDetailModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background:#0f1624;border:1px solid rgba(255,255,255,.12);border-radius:12px">
                <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,.09)">
                    <div>
                        <h5 class="modal-title mb-0" id="simFeedModalTitle">Event Details</h5>
                        <p class="text-muted mb-0" style="font-size:.7rem" id="simFeedModalSub">—</p>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0">
                    <!-- Tab strip -->
                    <div class="d-flex" style="border-bottom:1px solid rgba(255,255,255,.09)">
                        <button id="sfmTabFmt" onclick="sfmSwitch('fmt')"
                                class="btn btn-link btn-sm px-4 py-2"
                                style="color:#60a5fa;font-size:.75rem;border-radius:0;border-bottom:2px solid #3b82f6">
                            <i class="bi bi-list-ul me-1"></i>Formatted
                        </button>
                        <button id="sfmTabRaw" onclick="sfmSwitch('raw')"
                                class="btn btn-link btn-sm px-4 py-2"
                                style="color:#64748b;font-size:.75rem;border-radius:0;border-bottom:2px solid transparent">
                            <i class="bi bi-braces me-1"></i>Raw JSON
                        </button>
                    </div>
                    <div id="sfmBodyFmt" style="padding:12px 16px;max-height:340px;overflow-y:auto"></div>
                    <div id="sfmBodyRaw" style="display:none;padding:12px 16px;max-height:340px;overflow-y:auto">
                        <pre id="sfmRawPre" style="font-size:.68rem;color:#94a3b8;margin:0;white-space:pre-wrap"></pre>
                    </div>
                </div>
                <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,.09)">
                    <button class="btn btn-outline-secondary btn-sm" id="sfmCopyBtn"
                            onclick="sfmCopy()">
                        <i class="bi bi-clipboard me-1"></i>Copy JSON
                    </button>
                    <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Hidden anti-forgery for simulation AJAX -->
    <form id="simAFForm" style="display:none">@Html.AntiForgeryToken()</form>

    <script id="simData" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
        zones   = Model.AllZones.Select(z => new { zoneId = z.ZoneId, zoneName = z.ZoneName, highwayId = z.HighwayId }),
        servers = Model.AllSwitchServers.Select(s => new { serverId = s.ServerId, serverName = s.ServerName, zoneId = s.ZoneId, ipAddress = s.IpAddress, port = s.Port, status = s.Status })
    }))
    </script>
}
else
{
    <!-- ── Format Config Cards ─────────────────────────────────────────────── -->
    <div class="row g-3 mb-4">
    @foreach (var c in shown)
    {
        var fields = c.EnabledFieldsRaw?.Split(',', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
        <div class="col-md-6 col-xl-4">
            <div class="mss-card" id="card_@c.Id">
                <div class="mss-card-body">
                    <div class="fw-bold small mb-1">@c.FormatName</div>
                    <div class="font-monospace text-muted mb-1" style="font-size:.62rem">@c.SourceId</div>
                    @if (!string.IsNullOrEmpty(c.InputSource))
                    { <div class="font-monospace text-primary mb-1" style="font-size:.62rem">→ @c.InputSource</div> }
                    <div class="text-muted" style="font-size:.72rem">@c.Description</div>
                    <div class="d-flex flex-wrap gap-1 mt-2">
                        @foreach (var f in fields.Take(4))
                        { <span class="badge bg-secondary font-monospace" style="font-size:.6rem">@f</span> }
                        @if (fields.Length > 4)
                        { <span class="badge bg-secondary font-monospace" style="font-size:.6rem">+@(fields.Length-4)</span> }
                    </div>
                    <div class="d-flex gap-2 mt-3 flex-wrap">
                        <button type="button" class="btn btn-outline-success btn-sm flex-fill" onclick="generateAjax(@c.Id, this)">
                            <i class="bi bi-play me-1"></i>Generate Payload
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" onclick="openEditFmt(@c.Id)" data-bs-toggle="modal" data-bs-target="#fmtModal">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <div class="dropdown">
                            <button class="btn btn-outline-info btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" title="Duplicate to another tab">
                                <i class="bi bi-copy"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end">
                                <li><span class="dropdown-header small">Duplicate to…</span></li>
                                @foreach (var (type, label, _) in tabDefs)
                                {
                                    if (type != Model.ActiveTab)
                                    {
                                        <li><a class="dropdown-item small" href="#" onclick="duplicateConfig(@c.Id,'@type');return false;">@label</a></li>
                                    }
                                }
                            </ul>
                        </div>
                        <button class="btn btn-outline-danger btn-sm"
                            onclick="ajaxFmtDelete(@c.Id,'@Model.ActiveTab','@c.FormatName')">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
                <div class="mss-payload-preview" id="preview_@c.Id">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="small fw-semibold text-success"><i class="bi bi-check-circle me-1"></i><span id="previewLabel_@c.Id"></span></span>
                        <div class="d-flex gap-1">
                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="copyPayloadInline(@c.Id)"><i class="bi bi-clipboard"></i></button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="closePreview(@c.Id)"><i class="bi bi-x"></i></button>
                        </div>
                    </div>
                    <pre class="mss-payload-code mb-0" id="previewCode_@c.Id" style="max-height:180px;overflow-y:auto;font-size:.65rem"></pre>
                </div>
            </div>
        </div>
    }
    @if (!shown.Any())
    { <div class="col-12"><p class="text-muted">No formats configured for this source type.</p></div> }
    </div>

    @if (Model.SavedPayloads.Any(p => p.SourceType == Model.ActiveTab))
    {
        <div class="mss-card">
            <div class="mss-card-header"><i class="bi bi-archive me-1"></i> Saved Payloads</div>
            <div class="mss-card-body p-0">
            @foreach (var p in Model.SavedPayloads.Where(p => p.SourceType == Model.ActiveTab))
            {
                <div class="mss-list-item">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="@(p.IsValid ? "text-success" : "text-danger") me-2"><i class="bi @(p.IsValid ? "bi-check-circle" : "bi-x-circle")"></i></span>
                            <span class="small fw-semibold">@p.Label</span>
                            <span class="text-muted small ms-2">@p.CreatedDate.ToString("yyyy-MM-dd HH:mm")</span>
                        </div>
                        <div class="d-flex gap-1">
                            <button class="btn btn-outline-secondary btn-sm" onclick="copySaved(@p.Id)"><i class="bi bi-clipboard"></i></button>
                            <form method="post" asp-action="DeletePayload" asp-route-id="@p.Id" asp-route-activeTab="@Model.ActiveTab" style="display:inline">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                            </form>
                        </div>
                    </div>
                    <pre class="mss-payload-code mt-2 mb-0" id="pl_@p.Id" style="max-height:8rem;overflow-y:auto;font-size:.65rem">@p.Payload</pre>
                </div>
            }
            </div>
        </div>
    }

    <script id="fmtData" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(allConfigs.Select(c => new {
        c.Id, c.SourceType, c.FormatName, c.SourceId, c.InputSource, c.Description,
        enabledFields = c.EnabledFieldsRaw?.Split(',', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>()
    })))
    </script>

    <div class="modal fade" id="fmtModal" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <div class="modal-content mss-modal">
          <div class="modal-header border-bottom border-secondary">
            <h5 class="modal-title" id="fmtModalTitle">Add Format Config</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <form id="fmtForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="fm_id" value="0" />
                <div class="row g-2 mb-3">
                    <div class="col-12"><label class="form-label small">Format Name *</label><input type="text" name="FormatName" id="fm_name" class="form-control" required /></div>
                    <div class="col-6"><label class="form-label small">Source ID</label><input type="text" name="SourceId" id="fm_sid" class="form-control font-monospace" /></div>
                    <div class="col-6"><label class="form-label small">Source Type</label>
                        <select name="SourceType" id="fm_type" class="form-select">
                            @foreach (var (type, label, _) in tabDefs)
                            { <option value="@type">@label</option> }
                        </select>
                    </div>
                    <div class="col-12"><label class="form-label small">Input Source (URL / stream)</label><input type="text" name="InputSource" id="fm_src" class="form-control" /></div>
                    <div class="col-12"><label class="form-label small">Description</label><input type="text" name="Description" id="fm_desc" class="form-control" /></div>
                </div>
                <div class="mb-3">
                    <label class="form-label small">Common Fields</label>
                    <div class="row g-1 overflow-auto" style="max-height:12rem">
                    @foreach (var f in commonFields)
                    {
                        <div class="col-6 col-md-4">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input fm-field" name="enabledFields" value="@f" id="ff_@f" />
                                <label class="form-check-label small font-monospace" for="ff_@f">@f</label>
                            </div>
                        </div>
                    }
                    </div>
                </div>
                <div class="mb-2">
                    <label class="form-label small">Custom Fields</label>
                    <div id="customFields"></div>
                    <button type="button" class="btn btn-outline-secondary btn-sm mt-1" onclick="addCustomField()">
                        <i class="bi bi-plus me-1"></i>Add Custom Field
                    </button>
                </div>
            </form>
          </div>
          <div class="modal-footer border-top border-secondary">
            <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button class="btn btn-primary" onclick="ajaxFmtSubmit()">Save</button>
          </div>
        </div>
      </div>
    </div>
}

@if (isSimTab)
{
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"
        integrity="sha384-9EQoUIJYrv09/oYhSxnw1VpLcfPw3BM9dE7+D/3wGUPeLLa7F9Z6OAoD+i/M6FK9"
        crossorigin="anonymous"></script>
<script src="~/js/vehicleScene.js"></script>
<script>
// ══════════════════════════════════════════════════════════════════════════
// DataInputFormats — Simulation tab JS
//   • Runs in its own browser tab (window.open from "View as 3D Scene")
//   • Broadcasts sim_started/sim_stopped via BroadcastChannel + localStorage
//   • doPost() result now returns vehicleId, vehicleType, direction for richer logging
// ══════════════════════════════════════════════════════════════════════════
var simRaw      = JSON.parse(document.getElementById('simData').textContent);
var simZones    = simRaw.zones   || [];
var simServers  = simRaw.servers || [];
var simTimer    = null;
var simDelayTmr = null;
var simTotal    = 0;
var simLogItems = [];
var eyewaysBroadcast = (typeof BroadcastChannel !== 'undefined') ? new BroadcastChannel('eyeways_sim') : null;

function simBroadcast(type, explicit) {
    var hwId = document.getElementById('simHighway').value || '';
    if (eyewaysBroadcast) eyewaysBroadcast.postMessage({ type: type, highwayId: hwId, explicit: explicit === true });
    try {
        localStorage.setItem('eyeways_sim_active',  type === 'sim_started' ? 'true' : 'false');
        localStorage.setItem('eyeways_sim_highway', hwId);
    } catch(e) {}
}

function simFilterDropdowns() {
    var hwId = document.getElementById('simHighway').value;
    var filtZones = hwId ? simZones.filter(function(z){ return z.highwayId === hwId; }) : simZones;
    rebuildOpts('simZone', filtZones, 'Any Zone', function(z){ return { val: z.zoneId, label: z.zoneName }; });
    simFilterServers();
}

function simFilterServers() {
    var hwId   = document.getElementById('simHighway').value;
    var zoneId = document.getElementById('simZone').value;
    var filtZones = hwId ? simZones.filter(function(z){ return z.highwayId === hwId; }) : simZones;
    var zoneIds   = zoneId ? [zoneId] : filtZones.map(function(z){ return z.zoneId; });
    var filtSrvs  = simServers.filter(function(s){ return zoneIds.indexOf(s.zoneId) >= 0; });
    rebuildOpts('simServer', filtSrvs, 'Any Server', function(s){
        var addr = s.ipAddress ? ' — ' + s.ipAddress + ':' + s.port : '';
        return { val: s.serverId, label: s.serverName + addr };
    });
}

function rebuildOpts(selId, items, blank, mapper) {
    var sel = document.getElementById(selId);
    var cur = sel.value;
    sel.innerHTML = '<option value="">' + blank + '</option>';
    items.forEach(function(item) {
        var m   = mapper(item);
        var opt = document.createElement('option');
        opt.value = m.val; opt.textContent = m.label;
        sel.appendChild(opt);
    });
    var hasVal = Array.from(sel.options).some(function(o){ return o.value === cur; });
    if (hasVal) sel.value = cur;
}

simFilterDropdowns();

function startSim() {
    var delay    = parseInt(document.getElementById('simDelay').value)    * 1000;
    var interval = parseInt(document.getElementById('simInterval').value) * 1000;
    document.getElementById('btnStartSim').style.display = 'none';
    document.getElementById('btnStopSim').style.display  = '';
    setSimStatus('pending', delay > 0 ? ('Starting in ' + delay/1000 + 's…') : 'Starting…');
    simBroadcast('sim_started');

    function doPost() {
        var hwId     = document.getElementById('simHighway').value;
        var zoneId   = document.getElementById('simZone').value;
        var serverId = document.getElementById('simServer').value;
        var srcType  = document.getElementById('simType').value;
        var tok      = document.querySelector('#simAFForm input[name="__RequestVerificationToken"]').value;
        fetch('/DataInputFormats/SimulationPost', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
            body: 'highwayId='  + encodeURIComponent(hwId)     +
                  '&zoneId='    + encodeURIComponent(zoneId)   +
                  '&serverId='  + encodeURIComponent(serverId) +
                  '&sourceType='+ encodeURIComponent(srcType)  +
                  '&__RequestVerificationToken=' + encodeURIComponent(tok)
        })
        .then(function(r){ return r.json(); })
        .then(function(d){
            if (d.ok) {
                simTotal++;
                document.getElementById('simTotalBadge').textContent = simTotal + ' posted';
                setSimStatus('running', 'Running · ' + simTotal + ' posted · every ' + interval/1000 + 's');
                appendSimLog(d.payload, d.label, srcType, d);
                // Push directly into mini-3D feed without waiting for poll
                if (mini3DInitialized && d.eventId) {
                    var evObj = {
                        id: d.eventId, vehicleId: d.vehicleId, vehicleType: d.vehicleType,
                        direction: d.direction, speedMph: d.speedMph||null,
                        eventType: d.eventType||'detection', zoneId: d.zoneId||'',
                        highwayId: hwId, sourceType: srcType, isSimulated: true,
                        createdDate: new Date().toISOString()
                    };
                    addMini3DEvent(evObj);
                }
                // Re-broadcast so the 3D tab's delta-poll knows to keep polling
                simBroadcast('sim_started');
            }
        })
        .catch(function(e){ console.error('SimulationPost error', e); });
    }

    simDelayTmr = setTimeout(function() {
        if (!simTimer && !simDelayTmr) return;
        doPost();
        simTimer = setInterval(doPost, interval);
        simDelayTmr = null;
        setSimStatus('running', 'Running — posting every ' + interval/1000 + 's');
    }, delay);
}

function stopSim() {
    if (simTimer)    { clearInterval(simTimer);    simTimer    = null; }
    if (simDelayTmr) { clearTimeout(simDelayTmr);  simDelayTmr = null; }
    document.getElementById('btnStartSim').style.display = '';
    document.getElementById('btnStopSim').style.display  = 'none';
    setSimStatus('stopped', 'Stopped · ' + simTotal + ' total posted');
    simBroadcast('sim_stopped', true);  // explicit=true → 3D tab may exit sim mode
}

function setSimStatus(state, msg) {
    document.getElementById('simStatus').textContent = msg;
    var colors = { running: '#22c55e', pending: '#f59e0b', stopped: '#475569' };
    document.getElementById('simStatusDot').style.background = colors[state] || '#475569';
}

var typeColors = { physical: '#3b82f6', satellite: '#22c55e', telecom: '#f59e0b', tracker: '#a855f7' };
var vtIcons    = { sedan:'🚗', suv:'🚙', truck:'🚛', motorcycle:'🏍️', van:'🚐' };

function appendSimLog(payloadStr, label, srcType, resp) {
    var clr      = typeColors[srcType] || '#64748b';
    var now      = new Date().toLocaleTimeString();
    var vt       = (resp && resp.vehicleType) || '';
    var dir      = (resp && resp.direction)   || '';
    var vid      = (resp && resp.vehicleId)   || '';
    var icon     = vtIcons[vt] || '🚗';
    var safePayload = payloadStr.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    var safeForAttr = payloadStr.replace(/"/g,'&quot;');
    var dirLabel = dir==='N'?'↑N':dir==='S'?'↓S':dir==='E'?'→E':dir==='W'?'←W':dir||'';

    // Store event for modal
    var evIdx = simLogEventCounter++;
    var evData = null;
    try { evData = Object.assign({}, resp, { payloadStr: payloadStr }); } catch(e) {}
    if (evData) simLogEventMap[evIdx] = evData;

    var item = document.createElement('div');
    item.className = 'mss-list-item';
    item.style.cssText = 'border-left:3px solid ' + clr + ';padding-left:10px;cursor:pointer';
    item.title = 'Click to view event details';
    if (evData) {
        item.onclick = (function(idx){ return function(){ openSimLogModal(idx); }; })(evIdx);
    }
    item.innerHTML =
        '<div class="d-flex justify-content-between align-items-center mb-1">' +
          '<span class="small fw-semibold" style="color:' + clr + '">' + icon + ' ' + (label || srcType.toUpperCase()) +
            (vt   ? ' <span class="badge" style="background:rgba(255,255,255,.1);color:#e2e8f0;font-size:.58rem">' + vt + '</span>'    : '') +
            (dirLabel ? ' <span class="badge bg-secondary" style="font-size:.58rem">' + dirLabel + '</span>' : '') +
            '<span class="badge ms-1" style="background:rgba(255,255,255,.07);color:#64748b;font-size:.55rem"><i class="bi bi-search me-1"></i>details</span>' +
          '</span>' +
          '<div class="d-flex gap-1 align-items-center">' +
            '<span class="font-monospace text-muted" style="font-size:.6rem">' + now + '</span>' +
            '<button class="btn btn-outline-secondary btn-sm p-0 px-1" style="font-size:.65rem" ' +
              'title="Copy payload" onclick="event.stopPropagation();navigator.clipboard.writeText(this.dataset.p)"' +
              ' data-p="' + safeForAttr + '"><i class="bi bi-clipboard"></i></button>' +
          '</div>' +
        '</div>' +
        (vid ? '<div class="font-monospace text-muted mb-1" style="font-size:.6rem">ID: ' + vid + '</div>' : '') +
        '<pre style="font-size:.62rem;max-height:110px;overflow-y:auto;background:rgba(255,255,255,.04);' +
          'border-radius:4px;padding:6px;margin:0;color:#94a3b8">' + safePayload + '</pre>';

    var log = document.getElementById('simLog');
    var placeholder = log.querySelector('p');
    if (placeholder) log.innerHTML = '';
    log.insertBefore(item, log.firstChild);
    simLogItems.push(item);
    if (simLogItems.length > 50) {
        var old = simLogItems.shift();
        if (old.parentNode) old.parentNode.removeChild(old);
        // Clean up oldest map entry
        delete simLogEventMap[evIdx - 50];
    }
}

// ── Embedded 3D panel toggle ─────────────────────────────────────────────
var mini3DInitialized = false;
var mini3DPanelOpen   = false;

// Scene state (self-contained, no SceneManager conflict)
var m3Scene, m3Camera, m3Renderer, m3AnimId;
var m3Vehicles   = [];   // [{group, userData}]
var m3SeenIds    = new Set();
var m3PollTimer  = null;
var m3LastPoll   = null; // set on init so we only fetch events AFTER panel opens

// Lane layout: negative X = NB/WB lanes, positive X = SB/EB lanes
var M3_LANES = [-5.5, -3.5, -1.5, 1.5, 3.5, 5.5];

function toggle3DPanel() {
    var panel = document.getElementById('simScene3DPanel');
    var icon  = document.getElementById('icon3DPanel');
    mini3DPanelOpen = !mini3DPanelOpen;
    panel.style.display = mini3DPanelOpen ? '' : 'none';
    if (icon) icon.className = mini3DPanelOpen ? 'bi bi-chevron-up ms-1' : 'bi bi-chevron-down ms-1';
    if (mini3DPanelOpen) {
        if (!mini3DInitialized) initMini3D();
        setTimeout(function(){
            document.getElementById('simScene3DPanel').scrollIntoView({behavior:'smooth',block:'nearest'});
        }, 80);
    }
}

// ── Init ──────────────────────────────────────────────────────────────────
function initMini3D() {
    if (mini3DInitialized) return;
    mini3DInitialized = true;
    m3LastPoll = new Date().toISOString(); // anchor: only NEW events from here

    var container = document.getElementById('simMini3DContainer');
    var W = container.clientWidth  || 600;
    var H = container.clientHeight || 420;

    // ── Renderer (appended into container, not targeting <canvas> directly) ──
    m3Renderer = new THREE.WebGLRenderer({ antialias: true });
    m3Renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    m3Renderer.setSize(W, H);
    m3Renderer.shadowMap.enabled = true;

    // Replace the placeholder canvas with the real renderer canvas
    var placeholder = document.getElementById('simMiniCanvas');
    if (placeholder && placeholder.parentNode) {
        placeholder.parentNode.replaceChild(m3Renderer.domElement, placeholder);
    } else {
        container.appendChild(m3Renderer.domElement);
    }
    m3Renderer.domElement.style.cssText = 'width:100%;height:100%;display:block';

    // ── Scene ──
    m3Scene = new THREE.Scene();
    m3Scene.background = new THREE.Color(0x060d1a);
    m3Scene.fog = new THREE.Fog(0x060d1a, 55, 100);

    // ── Camera ──
    m3Camera = new THREE.PerspectiveCamera(52, W / H, 0.1, 200);
    m3Camera.position.set(0, 20, 26);
    m3Camera.lookAt(0, 0, 0);

    // ── Lights ──
    m3Scene.add(new THREE.AmbientLight(0x8fa8d8, 0.7));
    var sun = new THREE.DirectionalLight(0xffeebb, 1.3);
    sun.position.set(15, 40, 20);
    sun.castShadow = true;
    m3Scene.add(sun);
    m3Scene.add(new THREE.PointLight(0x3b82f6, 0.4, 60));

    // ── Road ──
    _m3BuildRoad();

    // ── Resize ──
    window.addEventListener('resize', function() {
        var nw = container.clientWidth || 600, nh = container.clientHeight || 420;
        m3Camera.aspect = nw / nh;
        m3Camera.updateProjectionMatrix();
        m3Renderer.setSize(nw, nh);
    });

    // ── Click-to-inspect ──
    m3Renderer.domElement.addEventListener('click', function(e) {
        var rect = m3Renderer.domElement.getBoundingClientRect();
        var mx = ((e.clientX - rect.left) / rect.width)  * 2 - 1;
        var my = -((e.clientY - rect.top)  / rect.height) * 2 + 1;
        var rc = new THREE.Raycaster();
        rc.setFromCamera({x: mx, y: my}, m3Camera);
        var meshes = [];
        m3Vehicles.forEach(function(v) {
            v.group.traverse(function(c) { if (c.isMesh) { c.__vIdx = v.idx; meshes.push(c); } });
        });
        var hits = rc.intersectObjects(meshes, false);
        if (hits.length > 0) {
            var idx = hits[0].object.__vIdx;
            var veh = m3Vehicles.find(function(v){ return v.idx === idx; });
            if (veh && veh.event) openFeedModal(veh.event, null);
        }
    });

    // Hide loader
    var loader = document.getElementById('simMini3DLoader');
    if (loader) loader.style.display = 'none';

    // ── Start render loop ──
    _m3Animate();

    // ── Load snapshot of existing sim events, then start delta-poll ──
    _m3LoadSnapshot();
}

function _m3BuildRoad() {
    // Ground
    var gnd = new THREE.Mesh(
        new THREE.PlaneGeometry(200, 200),
        new THREE.MeshLambertMaterial({ color: 0x0a0f1a })
    );
    gnd.rotation.x = -Math.PI / 2;
    gnd.receiveShadow = true;
    m3Scene.add(gnd);

    // Road surface
    var road = new THREE.Mesh(
        new THREE.PlaneGeometry(14, 90),
        new THREE.MeshLambertMaterial({ color: 0x1e293b })
    );
    road.rotation.x = -Math.PI / 2;
    road.position.y = 0.01;
    road.receiveShadow = true;
    m3Scene.add(road);

    // Kerbs
    [-7.2, 7.2].forEach(function(cx) {
        var k = new THREE.Mesh(
            new THREE.BoxGeometry(0.3, 0.15, 90),
            new THREE.MeshLambertMaterial({ color: 0x2c3a52 })
        );
        k.position.set(cx, 0.07, 0);
        m3Scene.add(k);
    });

    // Lane markings — dashed whites between lanes
    var dashMat = new THREE.MeshBasicMaterial({ color: 0xffffff, opacity: 0.45, transparent: true });
    var solidMat = new THREE.MeshBasicMaterial({ color: 0xffffff, opacity: 0.7, transparent: true });
    var centMat  = new THREE.MeshBasicMaterial({ color: 0xf59e0b, opacity: 0.8, transparent: true });

    // Centre double-yellow
    [-0.2, 0.2].forEach(function(ox) {
        var cy = new THREE.Mesh(new THREE.PlaneGeometry(0.1, 90), centMat);
        cy.rotation.x = -Math.PI / 2;
        cy.position.set(ox, 0.02, 0);
        m3Scene.add(cy);
    });
    // Dashed lane lines
    [-3.5, 3.5].forEach(function(lx) {
        for (var dz = -42; dz < 43; dz += 7) {
            var d = new THREE.Mesh(new THREE.PlaneGeometry(0.12, 4), dashMat);
            d.rotation.x = -Math.PI / 2;
            d.position.set(lx, 0.02, dz);
            m3Scene.add(d);
        }
    });
    // Outer solid white
    [-6.8, 6.8].forEach(function(lx) {
        var s = new THREE.Mesh(new THREE.PlaneGeometry(0.12, 90), solidMat);
        s.rotation.x = -Math.PI / 2;
        s.position.set(lx, 0.02, 0);
        m3Scene.add(s);
    });
}

var m3VehicleIdx = 0;

function _m3SpawnVehicle(ev) {
    if (!m3Scene) return;

    // Pick lane based on direction
    var dir = ev.direction || 'S';
    var nbWb = (dir === 'N' || dir === 'W');
    var lanePool = nbWb ? [-5.5, -3.5, -1.5] : [1.5, 3.5, 5.5];
    var laneX = lanePool[Math.floor(Math.random() * lanePool.length)];
    var moveDir = nbWb ? -1 : 1;  // -1 = towards negative Z, +1 = towards positive Z

    // Build mesh using vehicleBuildMesh from vehicleScene.js
    var spec  = (typeof vehicleGetRandom === 'function') ? vehicleGetRandom(ev.vehicleType || null) : null;
    var group = (spec && typeof vehicleBuildMesh === 'function')
                    ? vehicleBuildMesh(spec)
                    : _m3FallbackMesh(ev);

    // Rotate to face travel direction
    group.rotation.y = nbWb ? Math.PI : 0;

    // Spawn at near end of road travelling through
    var startZ = moveDir > 0 ? -44 : 44;
    group.position.set(laneX, 0, startZ);
    group.castShadow = true;

    var speed = (ev.speedMph || 45) * 0.013;  // world units / frame at 60fps
    var idx   = m3VehicleIdx++;

    group.traverse(function(c) { if (c.isMesh) c.__vIdx = idx; });

    m3Scene.add(group);
    m3Vehicles.push({
        idx:   idx,
        group: group,
        speed: speed,
        moveDir: moveDir,
        event: ev,
        spec:  spec
    });
}

function _m3FallbackMesh(ev) {
    // Simple coloured box when vehicleScene.js not available
    var colors = { sedan:0x3b82f6, suv:0x22c55e, truck:0xf59e0b, motorcycle:0xa855f7, van:0xec4899 };
    var col = colors[ev.vehicleType] || 0x3b82f6;
    var grp = new THREE.Group();
    var body = new THREE.Mesh(
        new THREE.BoxGeometry(1.8, 0.7, 4.0),
        new THREE.MeshLambertMaterial({ color: col })
    );
    body.position.y = 0.35;
    grp.add(body);
    return grp;
}

function _m3Animate() {
    m3AnimId = requestAnimationFrame(_m3Animate);

    var toRemove = [];
    m3Vehicles.forEach(function(v, i) {
        v.group.position.z += v.speed * v.moveDir;
        // Fade out in last 8 units of road
        var distFromEnd = 44 - Math.abs(v.group.position.z);
        if (distFromEnd < 8) {
            var alpha = Math.max(0, distFromEnd / 8);
            v.group.traverse(function(c) {
                if (c.isMesh && c.material) {
                    c.material.transparent = true;
                    c.material.opacity = alpha;
                }
            });
        }
        if (Math.abs(v.group.position.z) > 46) toRemove.push(i);
    });

    // Remove exited vehicles (reverse so splice indices stay valid)
    for (var ri = toRemove.length - 1; ri >= 0; ri--) {
        var vi = toRemove[ri];
        m3Scene.remove(m3Vehicles[vi].group);
        m3Vehicles.splice(vi, 1);
    }

    m3Renderer.render(m3Scene, m3Camera);
}

function _m3LoadSnapshot() {
    // Load last 30 saved sim events so the scene isn't empty on open
    var hw = document.getElementById('simHighway').value || '';
    fetch('/api/events/scene?limit=30' + (hw ? '&highwayId=' + encodeURIComponent(hw) : ''))
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.events && d.events.length) {
                d.events.forEach(function(ev) { m3AddEvent(ev); });
            }
        })
        .catch(function() {})
        .finally(function() { _m3StartPoll(); });
}

function _m3StartPoll() {
    if (m3PollTimer) return;
    m3PollTimer = setInterval(function() {
        var hw = document.getElementById('simHighway').value || '';
        var url = '/api/events/simulation?since=' + encodeURIComponent(m3LastPoll)
                + (hw ? '&highwayId=' + encodeURIComponent(hw) : '');
        fetch(url)
            .then(function(r) { return r.json(); })
            .then(function(d) {
                if (!d.events || !d.events.length) return;
                m3LastPoll = d.serverTime || m3LastPoll;
                d.events.forEach(function(ev) { m3AddEvent(ev); });
            })
            .catch(function() {});
    }, 2000);
}

function m3AddEvent(ev) {
    // Dedup by id (string or number)
    var key = String(ev.id || ev.vehicleId + '_' + ev.createdDate);
    if (m3SeenIds.has(key)) return;
    m3SeenIds.add(key);

    _m3SpawnVehicle(ev);
    pushMini3DFeed(ev);

    var cnt = document.getElementById('sim3dFeedCount');
    if (cnt) cnt.textContent = m3SeenIds.size + ' vehicles';
}

// Alias used by doPost immediate-push path
function addMini3DEvent(ev) { m3AddEvent(ev); }

// ── Mini-3D feed list rendering ───────────────────────────────────────────
var MINI_EVENT_COLORS = {detection:'#22c55e',merge:'#3b82f6',conflict:'#ef4444',speeding:'#f59e0b',fault:'#8b5cf6',ambient:'#64748b'};

function pushMini3DFeed(ev) {
    mini3DFeedItems.unshift(ev);
    if (mini3DFeedItems.length > 40) mini3DFeedItems.length = 40;
    renderMini3DFeed();
}

function renderMini3DFeed() {
    var feed = document.getElementById('simMini3DFeed');
    if (!feed) return;
    var empty = document.getElementById('simMini3DFeedEmpty');
    if (empty) empty.style.display = 'none';
    var vtIcons2 = {sedan:'🚗',suv:'🚙',truck:'🚛',motorcycle:'🏍️',van:'🚐'};
    feed.innerHTML = mini3DFeedItems.map(function(ev, idx){
        var ec  = MINI_EVENT_COLORS[ev.eventType]||'#64748b';
        var ico = vtIcons2[ev.vehicleType]||'🚗';
        var dir = ev.direction||'';
        var dl  = dir==='N'?'↑N':dir==='S'?'↓S':dir==='E'?'→E':dir==='W'?'←W':dir||'';
        var t   = ev.createdDate ? new Date(ev.createdDate).toLocaleTimeString() : '';
        return '<div class="mss-list-item" style="cursor:pointer;padding:.32rem .6rem;border-left:2px solid '+ec+'" '+
               'onclick="openFeedModalById('+idx+')" title="Click for details">'+
               '<div class="d-flex justify-content-between align-items-center">'+
               '<span>'+ico+' <span class="fw-semibold" style="font-size:.72rem">'+ev.vehicleId+'</span>'+
               (dl?'<span class="badge bg-secondary ms-1" style="font-size:.55rem">'+dl+'</span>':'')+
               '</span>'+
               '<span class="font-monospace text-muted" style="font-size:.58rem">'+t+'</span></div>'+
               '<div class="d-flex gap-2 mt-1" style="font-size:.62rem">'+
               '<span style="color:'+ec+'">●&nbsp;'+ev.eventType+'</span>'+
               (ev.vehicleType?'<span class="text-muted">'+ev.vehicleType+'</span>':'')+
               (ev.speedMph?'<span class="text-muted">'+Math.round(ev.speedMph)+' mph</span>':'')+
               (ev.zoneId?'<span class="text-muted ms-auto">'+ev.zoneId+'</span>':'')+
               '</div></div>';
    }).join('');
}

function openFeedModalById(idx) {
    var ev = mini3DFeedItems[idx];
    if (!ev) return;
    openFeedModal(ev, null);
}

// ── Feed detail modal ─────────────────────────────────────────────────────
var sfmCurrentRaw = null;

function openFeedModal(ev, grpOrNull) {
    if (!ev) return;
    sfmCurrentRaw = ev;
    var vtIcons3 = {sedan:'🚗',suv:'🚙',truck:'🚛',motorcycle:'🏍️',van:'🚐'};
    var ico = vtIcons3[ev.vehicleType]||'🚗';
    document.getElementById('simFeedModalTitle').innerHTML =
        ico + ' ' + (ev.vehicleId||'Unknown Vehicle') +
        '<span style="background:#f59e0b;color:#000;padding:1px 6px;border-radius:3px;font-size:.6rem;font-weight:700;margin-left:6px">SIM</span>';
    document.getElementById('simFeedModalSub').textContent =
        (ev.eventType||'detection') + (ev.createdDate?' · '+new Date(ev.createdDate).toLocaleString():'');

    var dir = ev.direction||'';
    var dl  = dir==='N'?'↑ Northbound':dir==='S'?'↓ Southbound':dir==='E'?'→ Eastbound':dir==='W'?'← Westbound':dir||'—';
    var rows = [
        ['Vehicle ID',    ev.vehicleId||'—'],
        ['Vehicle Type',  ev.vehicleType||'—'],
        ['Make / Model',  (ev.make||'')+(ev.model?' '+ev.model:'') || '—'],
        ['Direction',     dl],
        ['Speed',         ev.speedMph ? Math.round(ev.speedMph)+' mph' : '—'],
        ['Event Type',    ev.eventType||'—'],
        ['Zone',          ev.zoneId||'—'],
        ['Highway',       ev.highwayId||'—'],
        ['Source Type',   ev.sourceType||'—'],
        ['Is Simulated',  ev.isSimulated===true||ev.isSimulation===true ? '✅ Yes' : '❌ No'],
        ['GPS',           (ev.latitude&&ev.longitude) ? ev.latitude+', '+ev.longitude : '—'],
        ['Signal Str.',   ev.signalStrength!=null ? ev.signalStrength+' dBm' : '—'],
        ['Altitude',      ev.altitudeFt!=null ? ev.altitudeFt+' ft' : '—'],
        ['Heading',       ev.heading!=null ? ev.heading+'°' : '—'],
        ['Recorded At',   ev.createdDate ? new Date(ev.createdDate).toLocaleString() : '—'],
    ];

    var ec = MINI_EVENT_COLORS[ev.eventType]||'#64748b';
    document.getElementById('sfmBodyFmt').innerHTML = rows.map(function(r){
        return '<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.05)">'+
               '<span style="color:#64748b;font-size:.73rem">'+r[0]+'</span>'+
               '<span style="color:#e2e8f0;font-size:.73rem;font-weight:600;text-align:right;max-width:220px;'+
               'overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+r[1]+'</span></div>';
    }).join('') +
    '<div style="margin-top:10px;padding:6px 10px;border-radius:6px;background:rgba(255,255,255,.04);display:flex;gap:8px;align-items:center">'+
    '<span style="color:'+ec+';font-size:1rem">●</span>'+
    '<span style="color:#e2e8f0;font-size:.8rem;font-weight:600">'+ev.eventType+'</span>'+
    (ev.speedMph?'<span class="text-muted ms-auto" style="font-size:.72rem">'+Math.round(ev.speedMph)+' mph</span>':'')+
    '</div>';

    document.getElementById('sfmRawPre').textContent = JSON.stringify(ev, null, 2);
    sfmSwitch('fmt');

    var modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('simFeedDetailModal'));
    modal.show();
}

function sfmSwitch(tab) {
    document.getElementById('sfmBodyFmt').style.display = tab==='fmt' ? '' : 'none';
    document.getElementById('sfmBodyRaw').style.display = tab==='raw' ? '' : 'none';
    document.getElementById('sfmTabFmt').style.color      = tab==='fmt' ? '#60a5fa' : '#64748b';
    document.getElementById('sfmTabFmt').style.borderBottom = tab==='fmt' ? '2px solid #3b82f6' : '2px solid transparent';
    document.getElementById('sfmTabRaw').style.color      = tab==='raw' ? '#60a5fa' : '#64748b';
    document.getElementById('sfmTabRaw').style.borderBottom = tab==='raw' ? '2px solid #3b82f6' : '2px solid transparent';
}

function sfmCopy() {
    if (!sfmCurrentRaw) return;
    navigator.clipboard.writeText(JSON.stringify(sfmCurrentRaw, null, 2)).then(function(){
        var btn = document.getElementById('sfmCopyBtn');
        btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Copied!';
        setTimeout(function(){ btn.innerHTML = '<i class="bi bi-clipboard me-1"></i>Copy JSON'; }, 1500);
    });
}

