@model EyewaysMergeSafeServer.ViewModels.SensorViewModel
@{ ViewData["Title"] = "Sensors"; ViewBag.Highways = Model.Highways; ViewBag.SelectedHighwayId = Model.SelectedHighwayId; }
@{
    var deviceTypes = new[]{"all","camera","lidar","radar","vehicle tag reader","signal receiver"};
    var typeIcons = new Dictionary<string,string>{
        {"camera","bi-camera-video"},{"lidar","bi-upc-scan"},{"radar","bi-broadcast"},
        {"vehicle tag reader","bi-tag"},{"signal receiver","bi-reception-4"}};
    var typeColors = new Dictionary<string,string>{
        {"camera","text-primary"},{"lidar","text-purple"},{"radar","text-warning"},
        {"vehicle tag reader","text-success"},{"signal receiver","text-secondary"}};
}

<div class="mss-page-header">
    <div><h2 class="mss-page-title">Sensor Devices</h2><p class="mss-page-sub">Camera, LiDAR, and Radar hardware configuration</p></div>
    <div class="d-flex gap-2">
        <form method="get" class="d-flex gap-2">
            <input type="hidden" name="highwayId" value="@Model.SelectedHighwayId" />
            <select name="filterType" class="form-select form-select-sm" onchange="this.form.submit()">
                @foreach (var t in deviceTypes)
                { <option value="@t" selected="@(Model.FilterType == t ? "selected" : null)">@(t == "all" ? "All Types" : t)</option> }
            </select>
        </form>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#sensorModal" onclick="openNew()">
            <i class="bi bi-plus me-1"></i>Add Device
        </button>
    </div>
</div>

<div class="row g-3">
@foreach (var d in Model.Sensors)
{
    var icon = typeIcons.GetValueOrDefault(d.DeviceType, "bi-cpu");
    var colorCls = typeColors.GetValueOrDefault(d.DeviceType, "text-muted");
    <div class="col-md-6 col-xl-4">
        <div class="mss-card">
            <div class="mss-card-body">
                <div class="d-flex align-items-start gap-3 mb-3">
                    <div class="mss-device-icon @colorCls"><i class="bi @icon"></i></div>
                    <div class="flex-fill min-w-0">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="fw-bold text-truncate">@d.DeviceName</div>
                            <span class="mss-badge mss-badge--@d.Status ms-2 flex-shrink-0">@d.Status</span>
                        </div>
                        <div class="font-monospace text-muted" style="font-size:.65rem">@d.DeviceId</div>
                        <div class="small @colorCls">@d.DeviceType</div>
                    </div>
                </div>
                <div class="mss-kv-grid small">
                    <span class="text-muted">Zone</span><span class="font-monospace">@(d.ZoneId ?? "—")</span>
                    <span class="text-muted">Mile Marker</span><span>@d.MileMarker?.ToString("F2")</span>
                    <span class="text-muted">Firmware</span><span>@(d.FirmwareVersion ?? "—")</span>
                    <span class="text-muted">Last Heartbeat</span><span class="font-monospace" style="font-size:.65rem">@d.LastHeartbeat.ToString("HH:mm:ss")</span>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-outline-secondary btn-sm flex-fill"
                        onclick="openEdit(@d.Id,'@d.DeviceName','@d.DeviceId','@d.DeviceType','@(d.ZoneId ?? "")','@d.HighwayId',@(d.MileMarker ?? 0),@(d.Latitude ?? 0),@(d.Longitude ?? 0),'@d.Status','@(d.FirmwareVersion ?? "")')"
                        data-bs-toggle="modal" data-bs-target="#sensorModal">
                        <i class="bi bi-pencil"></i> Edit
                    </button>
                    <button class="btn btn-outline-danger btn-sm"
                        onclick="ajaxCrudDelete('/Sensors/Delete',@d.Id,'@Model.SelectedHighwayId','@d.DeviceName')">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
}
@if (!Model.Sensors.Any())
{ <div class="col-12"><p class="text-muted">No sensor devices found.</p></div> }
</div>

<div class="modal fade" id="sensorModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content mss-modal">
      <div class="modal-header border-bottom border-secondary">
        <h5 class="modal-title" id="sensorModalTitle">Add Sensor Device</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="sensorForm" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="sd_id" value="0" />
            <div class="row g-2">
                <div class="col-12"><label class="form-label small">Device Name *</label><input type="text" name="DeviceName" id="sd_name" class="form-control" required /></div>
                <div class="col-6"><label class="form-label small">Device ID *</label><input type="text" name="DeviceId" id="sd_did" class="form-control font-monospace" required /></div>
                <div class="col-6"><label class="form-label small">Device Type</label>
                    <select name="DeviceType" id="sd_type" class="form-select">
                        @foreach (var t in new[]{"camera","lidar","radar","vehicle tag reader","signal receiver"})
                        { <option value="@t">@t</option> }
                    </select>
                </div>
                <div class="col-6"><label class="form-label small">Zone ID</label><input type="text" name="ZoneId" id="sd_zone" class="form-control font-monospace" /></div>
                <div class="col-6"><label class="form-label small">Highway ID</label><input type="text" name="HighwayId" id="sd_hw" class="form-control font-monospace" value="@Model.SelectedHighwayId" /></div>
                <div class="col-6"><label class="form-label small">Mile Marker</label><input type="number" step="0.01" name="MileMarker" id="sd_mm" class="form-control" /></div>
                <div class="col-6"><label class="form-label small">Firmware Version</label><input type="text" name="FirmwareVersion" id="sd_fw" class="form-control" /></div>
                <div class="col-6"><label class="form-label small">Latitude</label><input type="number" step="any" name="Latitude" id="sd_lat" class="form-control" /></div>
                <div class="col-6"><label class="form-label small">Longitude</label><input type="number" step="any" name="Longitude" id="sd_lon" class="form-control" /></div>
                <div class="col-6"><label class="form-label small">Status</label>
                    <select name="Status" id="sd_status" class="form-select">
                        @foreach (var st in new[]{"online","offline","fault","calibrating","maintenance"})
                        { <option value="@st">@st</option> }
                    </select>
                </div>
            </div>
        </form>
      </div>
      <div class="modal-footer border-top border-secondary d-flex justify-content-between">
        <button class="btn btn-outline-info btn-sm" type="button" onclick="startBarcodeScan()">
            <i class="bi bi-upc-scan me-1"></i>Scan QR / Barcode
        </button>
        <div>
            <button class="btn btn-secondary me-2" data-bs-dismiss="modal">Cancel</button>
            <button class="btn btn-primary" onclick="ajaxCrudSubmit('sensorForm','sensorModal')">Save</button>
        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
function startBarcodeScan() {
    var result = prompt('Barcode / QR scan (paste JSON or device ID string):');
    if (!result) return;
    try {
        var obj = JSON.parse(result);
        if (obj.device_id)   document.getElementById('sd_did').value = obj.device_id;
        if (obj.device_type) document.getElementById('sd_type').value = obj.device_type;
        if (obj.zone_id)     document.getElementById('sd_zone').value = obj.zone_id;
        if (obj.latitude)    document.getElementById('sd_lat').value = obj.latitude;
        if (obj.longitude)   document.getElementById('sd_lon').value = obj.longitude;
        if (obj.firmware)    document.getElementById('sd_fw').value = obj.firmware;
        if (obj.mile_marker) document.getElementById('sd_mm').value = obj.mile_marker;
    } catch(e) {
        document.getElementById('sd_did').value = result.trim();
    }
}

function openNew() {
    document.getElementById('sensorModalTitle').textContent = 'Add Sensor Device';
    document.getElementById('sensorForm').action = '/Sensors/Create';
    document.getElementById('sd_id').value = 0;
    ['sd_name','sd_did','sd_zone','sd_fw','sd_lat','sd_lon'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('sd_hw').value = '@Model.SelectedHighwayId';
    document.getElementById('sd_mm').value = '';
    document.getElementById('sd_type').value = 'camera';
    document.getElementById('sd_status').value = 'online';
}
function openEdit(id,name,did,dtype,zone,hw,mm,lat,lon,status,fw) {
    document.getElementById('sensorModalTitle').textContent = 'Edit Sensor Device';
    document.getElementById('sensorForm').action = '/Sensors/Edit';
    document.getElementById('sd_id').value = id;
    document.getElementById('sd_name').value = name;
    document.getElementById('sd_did').value = did;
    document.getElementById('sd_type').value = dtype;
    document.getElementById('sd_zone').value = zone;
    document.getElementById('sd_hw').value = hw;
    document.getElementById('sd_mm').value = mm;
    document.getElementById('sd_lat').value = lat;
    document.getElementById('sd_lon').value = lon;
    document.getElementById('sd_status').value = status;
    document.getElementById('sd_fw').value = fw;
}

function ajaxCrudSubmit(formId, modalId) {
    var form = document.getElementById(formId);
    if (!form.reportValidity()) return;
    fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
        body: new URLSearchParams(new FormData(form)).toString()
    }).then(function(r){ return r.json(); })
      .then(function(d){ if (d.ok) { bootstrap.Modal.getInstance(document.getElementById(modalId))?.hide(); window.location.reload(); } else alert('Error: '+(d.error||'Save failed')); })
      .catch(function(e){ console.error(e); });
}

function ajaxCrudDelete(action, id, highwayId, name) {
    if (!confirm('Delete '+name+'?')) return;
    var tok = document.querySelector('input[name="__RequestVerificationToken"]');
    fetch(action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
        body: 'id='+id+'&highwayId='+encodeURIComponent(highwayId||'')+'&__RequestVerificationToken='+encodeURIComponent(tok?tok.value:'')
    }).then(function(r){ return r.json(); })
      .then(function(d){ if (d.ok) window.location.reload(); else alert('Delete failed'); })
      .catch(function(e){ console.error(e); });
}
</script>
}
