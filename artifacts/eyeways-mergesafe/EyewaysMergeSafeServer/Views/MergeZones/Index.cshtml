@model EyewaysMergeSafeServer.ViewModels.MergeZoneViewModel
@{ ViewData["Title"] = "Merge Zones"; ViewBag.Highways = Model.Highways; ViewBag.SelectedHighwayId = Model.SelectedHighwayId; }

<div class="mss-page-header">
    <div><h2 class="mss-page-title">Merge Zones</h2><p class="mss-page-sub">Manage highway merge zone definitions</p></div>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#zoneModal" onclick="openNew()">
        <i class="bi bi-plus me-1"></i>Add Zone
    </button>
</div>

<div class="row g-3">
@foreach (var z in Model.Zones)
{
    <div class="col-md-6 col-xl-4">
        <div class="mss-card">
            <div class="mss-card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <div class="fw-bold">@z.ZoneName</div>
                        <div class="font-monospace text-muted" style="font-size:.65rem">@z.ZoneId</div>
                    </div>
                    <span class="mss-badge mss-badge--@z.Status">@z.Status</span>
                </div>
                <div class="mss-kv-grid small">
                    <span class="text-muted">Mile Marker</span><span>MM @z.MileMarker</span>
                    <span class="text-muted">Geofence</span><span>@z.GeofenceRadius m</span>
                    <span class="text-muted">Coords</span><span class="font-monospace">@z.Latitude?.ToString("F5"), @z.Longitude?.ToString("F5")</span>
                    <span class="text-muted">Highway</span><span class="font-monospace">@z.HighwayId</span>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-outline-secondary btn-sm flex-fill"
                        onclick="openEdit(@z.Id,'@z.ZoneName','@z.ZoneId','@z.HighwayId',@(z.MileMarker??0),@(z.Latitude??0),@(z.Longitude??0),@z.GeofenceRadius,'@z.Status')"
                        data-bs-toggle="modal" data-bs-target="#zoneModal">
                        <i class="bi bi-pencil"></i> Edit
                    </button>
                    <button class="btn btn-outline-danger btn-sm"
                        onclick="ajaxCrudDelete('/MergeZones/Delete',@z.Id,'@Model.SelectedHighwayId','@z.ZoneName')">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
}
@if (!Model.Zones.Any())
{ <div class="col-12"><p class="text-muted">No merge zones found. Add one above.</p></div> }
</div>

<div class="modal fade" id="zoneModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content mss-modal">
      <div class="modal-header border-bottom border-secondary">
        <h5 class="modal-title" id="zoneModalTitle">Add Merge Zone</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="zoneForm" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="f_id" value="0" />
            <div class="row g-2">
                <div class="col-12"><label class="form-label small">Zone Name *</label><input type="text" name="ZoneName" id="f_zoneName" class="form-control" required /></div>
                <div class="col-6"><label class="form-label small">Zone ID *</label><input type="text" name="ZoneId" id="f_zoneId" class="form-control font-monospace" required /></div>
                <div class="col-6"><label class="form-label small">Highway ID *</label><input type="text" name="HighwayId" id="f_hwId" class="form-control font-monospace" value="@Model.SelectedHighwayId" required /></div>
                <div class="col-6"><label class="form-label small">Mile Marker</label><input type="number" step="0.1" name="MileMarker" id="f_mm" class="form-control" /></div>
                <div class="col-6"><label class="form-label small">Geofence Radius (m)</label><input type="number" name="GeofenceRadius" id="f_gfr" class="form-control" value="500" /></div>
                <div class="col-6"><label class="form-label small">Latitude</label><input type="number" step="any" name="Latitude" id="f_lat" class="form-control" /></div>
                <div class="col-6"><label class="form-label small">Longitude</label><input type="number" step="any" name="Longitude" id="f_lon" class="form-control" /></div>
                <div class="col-12"><label class="form-label small">Status</label>
                    <select name="Status" id="f_status" class="form-select">
                        @foreach (var s in new[]{"active","inactive","fault","maintenance"})
                        { <option value="@s">@s</option> }
                    </select>
                </div>
            </div>
        </form>
      </div>
      <div class="modal-footer border-top border-secondary">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary" onclick="ajaxCrudSubmit('zoneForm','zoneModal')">Save</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
function openNew() {
    document.getElementById('zoneModalTitle').textContent = 'Add Merge Zone';
    document.getElementById('zoneForm').action = '/MergeZones/Create';
    document.getElementById('f_id').value = 0;
    document.getElementById('f_zoneName').value = '';
    document.getElementById('f_zoneId').value = '';
    document.getElementById('f_hwId').value = '@Model.SelectedHighwayId';
    document.getElementById('f_mm').value = '';
    document.getElementById('f_lat').value = '';
    document.getElementById('f_lon').value = '';
    document.getElementById('f_gfr').value = 500;
    document.getElementById('f_status').value = 'active';
}
function openEdit(id,name,zid,hwid,mm,lat,lon,gfr,status) {
    document.getElementById('zoneModalTitle').textContent = 'Edit Merge Zone';
    document.getElementById('zoneForm').action = '/MergeZones/Edit';
    document.getElementById('f_id').value = id;
    document.getElementById('f_zoneName').value = name;
    document.getElementById('f_zoneId').value = zid;
    document.getElementById('f_hwId').value = hwid;
    document.getElementById('f_mm').value = mm;
    document.getElementById('f_lat').value = lat;
    document.getElementById('f_lon').value = lon;
    document.getElementById('f_gfr').value = gfr;
    document.getElementById('f_status').value = status;
}

function ajaxCrudSubmit(formId, modalId) {
    var form = document.getElementById(formId);
    if (!form.reportValidity()) return;
    fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
        body: new URLSearchParams(new FormData(form)).toString()
    }).then(function(r){ return r.json(); })
      .then(function(d){ if (d.ok) { bootstrap.Modal.getInstance(document.getElementById(modalId))?.hide(); window.location.reload(); } else alert('Error: '+(d.error||'Save failed')); })
      .catch(function(e){ console.error(e); });
}

function ajaxCrudDelete(action, id, highwayId, name) {
    if (!confirm('Delete '+name+'?')) return;
    var tok = document.querySelector('input[name="__RequestVerificationToken"]');
    fetch(action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
        body: 'id='+id+'&highwayId='+encodeURIComponent(highwayId||'')+'&__RequestVerificationToken='+encodeURIComponent(tok?tok.value:'')
    }).then(function(r){ return r.json(); })
      .then(function(d){ if (d.ok) window.location.reload(); else alert('Delete failed'); })
      .catch(function(e){ console.error(e); });
}
</script>
}
